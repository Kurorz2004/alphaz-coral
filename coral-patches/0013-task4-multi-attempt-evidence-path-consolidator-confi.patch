+"""Tests for the LLM note consolidator groundwork (config fields +
+multi-attempt evidence verification/grouping).
+
+Task 1: ``agents.gate_consolidator_model`` / ``agents.gate_consolidator_timeout``
+config fields. Task 2: the ``evidence.attempts`` (list) path of
+``verify_note()`` and the set-intersection Rule 1 in ``group_notes()``.
+
+Fixture helpers (``_make_attempt`` / ``_write_note_file`` / ``_note_and_meta``)
+mirror ``tests/test_publication_gate.py`` exactly so the two suites read the
+same way; kept local (not imported) since they're tiny and this file must
+not depend on that one's internals shifting.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+from coral.config import AgentConfig, CoralConfig, TaskConfig
+from coral.hub.attempts import write_attempt
+from coral.hub.notes import _parse_frontmatter
+from coral.hub.publication import Verdict, group_notes, verify_note
+from coral.types import Attempt
+
+# --------------------------------------------------------------------------- #
+# Fixture helpers (mirrors tests/test_publication_gate.py)                    #
+# --------------------------------------------------------------------------- #
+
+_FULL_HASH = "7b1e4d001122334455667788990011223344aabb"
+_SHORT_HASH = _FULL_HASH[:12]
+_FULL_HASH_2 = "9c2f5e112233445566778899001122334455bbcc"
+_SHORT_HASH_2 = _FULL_HASH_2[:12]
+
+
+def _make_attempt(
+    commit: str,
+    agent: str = "island-0-agent-2",
+    score: float | None = 0.42,
+    metadata: dict | None = None,
+) -> Attempt:
+    return Attempt(
+        commit_hash=commit,
+        agent_id=agent,
+        title="a change",
+        score=score,
+        status="improved" if score is not None else "pending",
+        parent_hash=None,
+        timestamp="2026-03-14T17:00:00-00:00",
+        metadata=metadata or {},
+    )
+
+
+def _write_note(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text)
+
+
+def _write_note_file(path: Path, frontmatter: str, body: str = "# Title\nBody text.\n") -> Path:
+    _write_note(path, f"---\n{frontmatter}\n---\n\n{body}")
+    return path
+
+
+def _note_and_meta(path: Path) -> tuple[Path, dict]:
+    meta, _ = _parse_frontmatter(path.read_text())
+    return path, meta
+
+
+# --------------------------------------------------------------------------- #
+# Task 1 — config fields                                                      #
+# --------------------------------------------------------------------------- #
+
+
+def test_gate_consolidator_defaults():
+    config = AgentConfig()
+    assert config.gate_consolidator_model is None
+    assert config.gate_consolidator_timeout == 120
+
+
+def test_gate_consolidator_off_by_default_even_with_publication_gate_on():
+    config = AgentConfig(publication_gate=True)
+    assert config.gate_consolidator_model is None
+
+
+def test_gate_consolidator_model_dotlist_override_roundtrips():
+    config = CoralConfig(
+        task=TaskConfig(name="test", description="A test"),
+        agents=AgentConfig(),
+    )
+    assert config.agents.gate_consolidator_model is None
+
+    merged = CoralConfig.merge_dotlist(config, ["agents.gate_consolidator_model=sonnet"])
+
+    assert merged.agents.gate_consolidator_model == "sonnet"
+    # Original unchanged
+    assert config.agents.gate_consolidator_model is None
+
+
+# --------------------------------------------------------------------------- #
+# Task 2 — verify_note(): evidence.attempts (list) path                       #
+# --------------------------------------------------------------------------- #
+
+
+def test_verify_note_multi_attempt_all_match_is_verified_high(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        '      score: "0.4200"\n'
+        f"    - attempt: {_SHORT_HASH_2}\n"
+        '      score: "0.5500"\n',
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+def test_verify_note_multi_attempt_one_wrong_score_is_false_low(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        '      score: "0.4200"\n'
+        f"    - attempt: {_SHORT_HASH_2}\n"
+        '      score: "0.9900"\n',  # wrong, real score is 0.55
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is False
+    assert verdict.confidence == "low"
+    assert "0.99" in verdict.reason
+
+
+def test_verify_note_multi_attempt_unresolvable_hash_is_unverifiable(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        '      score: "0.4200"\n'
+        "    - attempt: deadbeef0000\n",  # doesn't resolve to any attempt
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+
+
+def test_verify_note_multi_attempt_empty_list_is_unverifiable(tmp_path):
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\nevidence:\n  attempts: []\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+    assert "no evidence cited" in verdict.reason
+
+
+def test_verify_note_multi_attempt_no_score_key_passes_vacuously(tmp_path):
+    # Documented choice: an entry without a `score` key passes once its hash
+    # resolves to a real, scored attempt -- it's citing the attempt without
+    # making a numeric claim, so there's nothing to check against it.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        f"    - attempt: {_SHORT_HASH_2}\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+def test_verify_note_multi_attempt_creator_check_skipped(tmp_path):
+    # A note authored by the consolidator, citing attempts from two DIFFERENT
+    # agents, still verifies True -- the creator == agent_id check that would
+    # fire on the single-attempt path is skipped entirely here.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-9", score=0.55))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        '      score: "0.4200"\n'
+        f"    - attempt: {_SHORT_HASH_2}\n"
+        '      score: "0.5500"\n',
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+def test_verify_note_multi_attempt_unscored_entry_is_unverifiable(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=None))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "consolidated.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        '      score: "0.4200"\n'
+        f"    - attempt: {_SHORT_HASH_2}\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+
+
+def test_verify_note_single_attempt_path_still_works_unchanged(tmp_path):
+    # Sanity check: the pre-existing single-attempt path is untouched by the
+    # new list branch (evidence.attempt, not evidence.attempts).
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        '  score: "0.4200"\n',
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+# --------------------------------------------------------------------------- #
+# Task 2 — group_notes(): Rule 1 set intersection                             #
+# --------------------------------------------------------------------------- #
+
+
+def test_group_notes_single_hash_groups_with_multi_attempt_superset(tmp_path):
+    # Note A cites a single hash H; note B (a consolidated note) cites {H, H2}.
+    # Rule 1 must merge them via set intersection ({H} & {H, H2} = {H}).
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, score=0.55))
+    notes_dir = tmp_path / "public" / "notes"
+    a = _write_note_file(
+        notes_dir / "a.md",
+        f"creator: agent-1\ncreated: 2026-03-10T00:00:00-00:00\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# A\nBody.\n",
+    )
+    b = _write_note_file(
+        notes_dir / "b.md",
+        "creator: coral-consolidator\n"
+        "created: 2026-03-12T00:00:00-00:00\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH}\n"
+        f"    - attempt: {_SHORT_HASH_2}\n",
+        body="# B consolidated\nBody.\n",
+    )
+    notes = [_note_and_meta(a), _note_and_meta(b)]
+    verdicts = {
+        a: Verdict(verified=True, confidence="high", reason="ok"),
+        b: Verdict(verified=True, confidence="high", reason="ok"),
+    }
+
+    groups = group_notes(notes, verdicts, coral_dir=tmp_path)
+
+    assert len(groups) == 1
+    # Most recent (b) wins representative -- same tier, later created.
+    assert groups[0].representative == b
+    assert groups[0].see_also == [a]
+
+
+def test_group_notes_disjoint_attempt_sets_and_tags_stay_separate(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, score=0.55))
+    third_hash = "aa11bb22cc33dd44ee55ff66001122334455aabb"
+    write_attempt(tmp_path, _make_attempt(third_hash, score=0.9))
+    notes_dir = tmp_path / "public" / "notes"
+    a = _write_note_file(
+        notes_dir / "a.md",
+        f"creator: agent-1\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# A\nBody.\n",
+    )
+    b = _write_note_file(
+        notes_dir / "b.md",
+        "creator: coral-consolidator\n"
+        "evidence:\n"
+        "  attempts:\n"
+        f"    - attempt: {_SHORT_HASH_2}\n"
+        f"    - attempt: {third_hash[:12]}\n",
+        body="# B consolidated\nBody.\n",
