diff --git a/tests/test_publication_gate.py b/tests/test_publication_gate.py
new file mode 100644
index 0000000..9c3fad7
--- /dev/null
+++ b/tests/test_publication_gate.py
@@ -0,0 +1,265 @@
+"""Tests for the publication gate (config flag + notes.py plumbing).
+
+Task 1: ``agents.publication_gate`` config flag (default False, dotlist
+override). Task 2: ``coral.hub.notes.upsert_frontmatter`` and the
+``format_notes_list`` status-token suffix. This file grows as later tasks
+land the gate's verification logic.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+from coral.config import AgentConfig, CoralConfig, TaskConfig
+from coral.hub.notes import _parse_frontmatter, format_notes_list, list_notes, upsert_frontmatter
+
+# --------------------------------------------------------------------------- #
+# Task 1 — config flag
+# --------------------------------------------------------------------------- #
+
+
+def test_publication_gate_default_false():
+    config = AgentConfig()
+    assert config.publication_gate is False
+
+
+def test_publication_gate_dotlist_override():
+    config = CoralConfig(
+        task=TaskConfig(name="test", description="A test"),
+        agents=AgentConfig(),
+    )
+    assert config.agents.publication_gate is False
+
+    merged = CoralConfig.merge_dotlist(config, ["agents.publication_gate=true"])
+    assert merged.agents.publication_gate is True
+    # Original unchanged
+    assert config.agents.publication_gate is False
+
+
+# --------------------------------------------------------------------------- #
+# Task 2 — upsert_frontmatter
+# --------------------------------------------------------------------------- #
+
+
+def _write_note(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text)
+
+
+def test_upsert_frontmatter_adds_and_updates_keys(tmp_path):
+    note = tmp_path / "public" / "notes" / "note.md"
+    _write_note(
+        note,
+        "---\n"
+        "creator: agent-1\n"
+        "created: 2026-03-14T00:00:00-00:00\n"
+        "claim: matmul tiling helps\n"
+        "---\n"
+        "\n"
+        "# Title\n"
+        "Body text.\n",
+    )
+
+    ok = upsert_frontmatter(note, {"coral_verified": True, "coral_confidence": "high"})
+    assert ok is True
+
+    entries = list_notes(tmp_path)
+    assert len(entries) == 1
+    entry = entries[0]
+    assert entry["coral_verified"] is True
+    assert entry["coral_confidence"] == "high"
+    # Untouched fields preserved
+    assert entry["creator"] == "agent-1"
+    assert entry["claim"] == "matmul tiling helps"
+    assert entry["body"] == "# Title\nBody text."
+
+
+def test_upsert_frontmatter_preserves_body_byte_for_byte(tmp_path):
+    note = tmp_path / "note.md"
+    body = "# Title\n\nSome body text with\nmultiple lines.\n\n- a\n- b\n"
+    _write_note(note, f"---\ncreator: agent-1\n---\n\n{body}")
+
+    upsert_frontmatter(note, {"coral_verified": False})
+
+    _, parsed_body = _parse_frontmatter(note.read_text())
+    assert parsed_body == body.strip()
+
+
+def test_upsert_frontmatter_idempotent(tmp_path):
+    note = tmp_path / "note.md"
+    _write_note(
+        note,
+        "---\ncreator: agent-1\nclaim: something\n---\n\n# Title\nBody.\n",
+    )
+
+    upsert_frontmatter(note, {"coral_verified": True, "coral_reason": "matches attempt 7b1e4d"})
+    after_first = note.read_text()
+
+    upsert_frontmatter(note, {"coral_verified": True, "coral_reason": "matches attempt 7b1e4d"})
+    after_second = note.read_text()
+
+    assert after_first == after_second
+
+
+def test_upsert_frontmatter_no_frontmatter_is_noop(tmp_path):
+    note = tmp_path / "note.md"
+    original = "# Just a title\nNo frontmatter here.\n"
+    _write_note(note, original)
+
+    ok = upsert_frontmatter(note, {"coral_verified": True})
+
+    assert ok is False
+    assert note.read_text() == original
+
+
+def test_upsert_frontmatter_atomic_no_leftover_tmp(tmp_path):
+    note = tmp_path / "note.md"
+    _write_note(note, "---\ncreator: agent-1\n---\n\n# Title\nBody.\n")
+
+    upsert_frontmatter(note, {"coral_verified": True})
+
+    leftover = [p for p in tmp_path.iterdir() if p.name != "note.md"]
+    assert leftover == []
+
+
+# Frontmatter exercising every shape a line-based patch must leave alone:
+# an ISO datetime, a double-quoted string, a flow-style list, a nested
+# mapping (with a key name — ``verified``— that collides with a top-level
+# key we upsert elsewhere), and a folded block scalar.
+_RICH_FRONTMATTER = (
+    "---\n"
+    "creator: agent-1\n"
+    'created: 2026-03-14T17:35:00-00:00\n'
+    'claim: "matmul inner-loop tiling at tile=32 improves score"\n'
+    "supersedes: [research/old-idea.md]\n"
+    "evidence:\n"
+    "  attempt: 7b1e4d\n"
+    "  verified: true\n"
+    "summary: >\n"
+    "  This is a folded\n"
+    "  multiline scalar that\n"
+    "  spans several lines.\n"
+    "---\n"
+    "\n"
+    "# Title\n"
+    "Body text.\n"
+)
+
+
+def test_upsert_frontmatter_preserves_rich_yaml_byte_for_byte(tmp_path):
+    note = tmp_path / "note.md"
+    _write_note(note, _RICH_FRONTMATTER)
+
+    upsert_frontmatter(note, {"coral_verified": True, "coral_confidence": "high"})
+    new_text = note.read_text()
+
+    # Every original line survives byte-for-byte, untouched.
+    for original_line in _RICH_FRONTMATTER.splitlines():
+        if original_line in ("---", ""):
+            continue
+        assert original_line in new_text, f"line mutated or dropped: {original_line!r}"
+
+    # New keys were appended inside the frontmatter block (before the
+    # closing '---'), not into the body.
+    _, front, body = new_text.split("---\n", 2)
+    assert "coral_verified: true" in front
+    assert "coral_confidence: high" in front
+    assert "coral_verified" not in body
+    assert "coral_confidence" not in body
+
+
+def test_upsert_frontmatter_replace_path_touches_only_that_line(tmp_path):
+    note = tmp_path / "note.md"
+    _write_note(note, _RICH_FRONTMATTER)
+
+    upsert_frontmatter(note, {"coral_reason": "matches attempt 7b1e4d"})
+    first_text = note.read_text()
+    assert "coral_reason: matches attempt 7b1e4d" in first_text
+
+    upsert_frontmatter(note, {"coral_reason": "score confirmed at 0.42"})
+    second_text = note.read_text()
+
+    # Old value gone, new value present, exactly one coral_reason line.
+    assert "coral_reason: matches attempt 7b1e4d" not in second_text
+    assert "coral_reason: score confirmed at 0.42" in second_text
+    assert second_text.count("coral_reason:") == 1
+
+    # Every other original line is still untouched.
+    for original_line in _RICH_FRONTMATTER.splitlines():
+        if original_line in ("---", ""):
+            continue
+        assert original_line in second_text, f"line mutated: {original_line!r}"
+
+
+def test_upsert_frontmatter_nested_key_not_confused_with_top_level(tmp_path):
+    note = tmp_path / "note.md"
+    _write_note(note, _RICH_FRONTMATTER)
+
+    # "verified" only exists nested inside evidence: — there is no top-level
+    # "verified:" key yet. Upserting it must append a new top-level line and
+    # must NOT touch (or match against) the nested "  verified: true" line.
+    upsert_frontmatter(note, {"verified": "pending"})
+    new_text = note.read_text()
+
+    assert "  verified: true\n" in new_text  # nested line untouched
+    front = new_text.split("---\n", 2)[1]
+    front_lines = front.splitlines()
+    top_level_verified = [ln for ln in front_lines if ln.startswith("verified:")]
+    assert top_level_verified == ["verified: pending"]
+
+
+# --------------------------------------------------------------------------- #
+# Task 2 — format_notes_list status token
+# --------------------------------------------------------------------------- #
+
+
+def test_format_notes_list_unchanged_without_coral_fields(tmp_path):
+    (tmp_path / "public" / "notes").mkdir(parents=True)
+    notes_file = tmp_path / "public" / "notes" / "notes.md"
+    notes_file.write_text(
+        "## [2026-03-11] ReLU works better\nDetails about ReLU activation...\n"
+    )
+
+    entries = list_notes(tmp_path)
+    formatted = format_notes_list(entries)
+
+    assert formatted == "  1. [2026-03-11] ReLU works better (unknown)"
+
+
+def test_format_notes_list_shows_verified_status(tmp_path):
+    notes_dir = tmp_path / "public" / "notes"
+    notes_dir.mkdir(parents=True)
+    (notes_dir / "a.md").write_text(
+        "---\ncreator: agent-1\ncoral_verified: true\ncoral_confidence: high\n---\n\n# Verified note\nBody.\n"
+    )
+
+    entries = list_notes(tmp_path)
+    formatted = format_notes_list(entries)
+
+    assert formatted.endswith("[verified/high]")
+
+
+def test_format_notes_list_shows_refuted_status(tmp_path):
+    notes_dir = tmp_path / "public" / "notes"
+    notes_dir.mkdir(parents=True)
+    (notes_dir / "a.md").write_text(
+        "---\ncreator: agent-1\ncoral_verified: false\n---\n\n# Refuted note\nBody.\n"
+    )
+
+    entries = list_notes(tmp_path)
+    formatted = format_notes_list(entries)
+
+    assert formatted.endswith("[refuted]")
+
+
+def test_format_notes_list_shows_unverified_status(tmp_path):
+    notes_dir = tmp_path / "public" / "notes"
+    notes_dir.mkdir(parents=True)
+    (notes_dir / "a.md").write_text(
+        "---\ncreator: agent-1\ncoral_confidence: medium\n---\n\n# Pending note\nBody.\n"
+    )
+
+    entries = list_notes(tmp_path)
+    formatted = format_notes_list(entries)
+
+    assert formatted.endswith("[unverified]")
