+def test_run_publication_pass_stabilizes_after_one_follow_up_pass(tmp_path, monkeypatch):
+    """Change-detection stores the PRE-pass signature (the guard-time
+    signature that triggered the run), not one recomputed after the pass
+    body finishes (see _run_publication_pass's docstring / Bug 1 fix). A
+    consequence: a pass's own writes (index.md, manifests, ...) make the
+    very next tick's signature differ from that stored baseline, so exactly
+    one follow-up pass runs right after any active pass. Once that
+    follow-up's writes stop changing anything, the signature stabilizes and
+    a third call short-circuits without re-entering the pass body.
+
+    This covers the empty-notes case; see
+    ``test_run_publication_pass_settles_after_one_follow_up_with_a_real_note``
+    for the same settling behavior with a real user note in play (which also
+    exercises the Bug 3 harvest-manifest-reconciliation fix -- without it,
+    a real note never settles at all)."""
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id = mgr.specs[0].agent_id
+    worktree = tmp_path / "agents" / agent1_id
+    mgr.handles = [_make_handle(agent1_id, worktree, tmp_path / "a1.log")]
+    (coral_dir / "public" / "notes").mkdir(parents=True)
+    (coral_dir / "public" / "attempts").mkdir(parents=True)
+    (worktree / ".claude" / "notes").mkdir(parents=True)
+    (worktree / ".claude" / "skills").mkdir(parents=True)
+
+    mgr._run_publication_pass()  # first call: runs the real (empty) pass
+    signature_after_first_call = mgr._last_publication_signature
+    assert signature_after_first_call is not None
+
+    calls: list[int] = []
+    monkeypatch.setattr(mgr, "_do_publication_pass", lambda: calls.append(1))
+
+    mgr._run_publication_pass()  # second call: the first pass's own writes
+    # (e.g. the view's generated index.md) changed the signature -> the
+    # guard does NOT short-circuit; exactly one follow-up pass runs.
+    assert calls == [1]
+    signature_after_second_call = mgr._last_publication_signature
+    assert signature_after_second_call != signature_after_first_call
+
+    mgr._run_publication_pass()  # third call: the (stubbed, no-op) follow-up
+    # changed nothing on disk -> now it genuinely short-circuits.
+    assert calls == [1]
+    assert mgr._last_publication_signature == signature_after_second_call
+
