+# --------------------------------------------------------------------------- #
+# (d) re-consolidation                                                        #
+# --------------------------------------------------------------------------- #
+
+
+def test_consolidation_reconsolidates_group_including_prior_consolidated_note(tmp_path):
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id, agent2_id, agent1_worktree, agent2_worktree = _setup_two_agent_group(mgr, coral_dir)
+
+    calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        calls.append(prompt)
+        # Both consolidation rounds end up citing the same expected set
+        # ({hash1, hash2}): round 1 groups a.md+b.md; round 2 groups the
+        # resulting consolidated note (citing both) with a new note citing
+        # just hash1, whose union is still {hash1, hash2}.
+        return _consolidation_response([(_FULL_HASH, 0.42), (_FULL_HASH_2, 0.55)])
+
+    mgr._gate_llm_call = fake_llm
+
+    for _ in range(3):
+        mgr._run_publication_pass()
