+def test_group_notes_rule2_similar_tags_forms_one_group(tmp_path):
+    # Clarke-Wright-like pair: different attempt hashes, tags nearly
+    # identical ({cw,2opt,relocate,swap} vs {cw,2opt,relocate,or-opt} ->
+    # jaccard 3/5 = 0.6 >= 0.5) -> one group via Rule 2.
+    notes_dir = tmp_path / "public" / "notes"
+    a = _write_note_file(
+        notes_dir / "a.md",
+        "creator: agent-1\n"
+        "created: 2026-03-10T00:00:00-00:00\n"
+        "tags: [cw, 2opt, relocate, swap]\n"
+        "evidence:\n  attempt: aaaa1111\n",
+        body="# Clarke-Wright with swap\nEarlier attempt.\n",
+    )
+    b = _write_note_file(
+        notes_dir / "b.md",
+        "creator: agent-2\n"
+        "created: 2026-03-12T00:00:00-00:00\n"
+        "tags: [cw, 2opt, relocate, or-opt]\n"
+        "evidence:\n  attempt: bbbb2222\n",
+        body="# Clarke-Wright with or-opt\nLater attempt.\n",
+    )
+    notes = [_note_and_meta(a), _note_and_meta(b)]
+    verdicts = {
+        a: Verdict(verified=True, confidence="high", reason="ok"),
+        b: Verdict(verified="unverifiable", confidence="medium", reason="pending"),
+    }
+
+    groups = group_notes(notes, verdicts)
+
+    assert len(groups) == 1
+    # a is the better-verified one (True beats "unverifiable") -> representative.
+    assert groups[0].representative == a
+    assert groups[0].see_also == [b]
+
