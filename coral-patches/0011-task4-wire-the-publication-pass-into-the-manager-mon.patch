+    def _publication_pass_signature(self) -> tuple[tuple[float, int], ...]:
+        """Cheap (max mtime, file count) fingerprint of everything a
+        publication pass reads/writes: the shared notes/attempts dirs plus
+        every live agent's served notes/skills view. Used by
+        :meth:`_run_publication_pass` to skip a tick when nothing moved
+        since the last pass — a full pass parses every note's frontmatter,
+        so this is much cheaper to compute every 5s than the pass itself.
+
+        TODO: the attempts dir signature walks every attempt file in the
+        store (``_dir_mtime_signature`` is a full ``rglob``), so this scan's
+        cost grows with the attempts store's size over a long run. Fine at
+        current scale; revisit (e.g. track a max-mtime cache instead of a
+        fresh walk) if that ever shows up in profiling.
+        """
+        if self.paths is None:
+            return ()
+        state_root = island_root(self.paths.coral_dir, None)
+        dirs = [state_root / "notes", state_root / "attempts"]
+        for handle in self.handles:
+            shared_dir = handle.worktree_path / self._runtime_for(handle.agent_id).shared_dir_name
+            dirs.append(shared_dir / "notes")
+            dirs.append(shared_dir / "skills")
+        return tuple(_dir_mtime_signature(d) for d in dirs)
+
+    def _run_publication_pass(self) -> None:
+        """One publication-gate tick: harvest -> verify/stamp -> group/rank
+        -> regenerate views (see ``coral.hub.publication``'s module
+        docstring for why that order is required).
+
+        No-op unless ``agents.publication_gate`` and ``agents.knowledge``
+        are both on. v1 is single-island only (``islands.count > 1`` skips
+        with a debug log — the harvested notes/skills channel is seeded as
+        real per-worktree directories, and ``repoint_shared_state`` already
+        refuses to repoint a gated real dir across islands). Cheap
+        change-detection (:meth:`_publication_pass_signature`) skips a tick
+        when nothing moved since the last one. The pass body never raises:
+        an exception is logged and the loop continues, so one bad note (or
+        a transient disk hiccup) never takes the monitor loop down with it.
+
+        The stored baseline is the PRE-pass signature — the guard-time
+        signature that triggered this run — not one recomputed after the
+        pass body finishes. Recomputing post-pass would fold this pass's
+        own writes (index.md, stamped frontmatter, ...) into the baseline,
+        permanently masking any agent write that happened to land during
+        the pass window: it would look identical to framework output and
+        never get re-harvested. Storing the pre-pass signature instead
+        means this pass's own writes make the *next* tick's signature
+        differ from the stored baseline, so exactly one extra follow-up
+        pass runs right after any active pass. That follow-up is cheap —
+        harvest and view writes are sha-gated no-ops, stamping is
+        idempotent — and then the signature stabilizes. A genuine mid-pass
+        agent write now differs from the stored (pre-pass) baseline too,
+        so it's harvested on that very next tick instead of being masked.
+        """
+        if not (self.config.agents.publication_gate and self.config.agents.knowledge):
+            return
+        if self.config.islands.count > 1:
+            logger.debug(
+                "Publication gate: multi-island runs are not supported yet "
+                "(v1 is single-island only) -- skipping"
+            )
+            return
+        if self.paths is None:
+            return
+
+        signature = self._publication_pass_signature()
+        if signature == self._last_publication_signature:
+            return
+
+        try:
+            self._do_publication_pass()
+        except Exception as e:
+            logger.exception(f"Publication gate pass failed: {e}")
+        finally:
+            # Store the PRE-pass signature (captured above, before the pass
+            # ran) -- never recompute here. See the docstring for why.
+            self._last_publication_signature = signature
+
+    def _do_publication_pass(self) -> None:
+        """Publication-gate pass body (single island): harvest every live
+        agent's note drafts into shared state, verify + stamp their
+        evidence, group/rank once, then regenerate every live agent's
+        served notes/skills view. Skills have no verify/group/rank step, so
+        :func:`generate_skills_view` harvests and mirrors them in one call
+        (see its docstring) — no separate ``harvest_skills`` call here.
+        """
+        if self.paths is None:
+            raise RuntimeError("run paths are not initialized; start_all() has not run")
+        coral_dir = self.paths.coral_dir
+        public_root = island_root(coral_dir, None)
+        shared_notes_dir = public_root / "notes"
+        shared_skills_dir = public_root / "skills"
+
+        # "live" here means currently-assigned handles (self.handles), not
+        # "process is alive" -- a dead-but-not-yet-reaped agent's view is
+        # still harvested/regenerated this pass.
+        live_agents = [
+            (handle.agent_id, handle.worktree_path, self._runtime_for(handle.agent_id).shared_dir_name)
+            for handle in self.handles
+        ]
+
+        # 1. Harvest agent-authored note drafts into shared state, for every
+        #    live agent, before anything regenerates a view from it.
+        #    harvest_drafts() mutates `manifest` in place with what it just
+        #    reconciled; persist that immediately so step 4's
+        #    generate_notes_view() (a separate call, its own load_manifest())
+        #    sees it -- see coral.hub.publication's module docstring
+        #    (pass-order note) and _harvest_from_view()'s docstring for why
+        #    skipping this turns every stamped note into a permanent false
+        #    "unsynced draft" that gets re-harvested (wiping the stamp) and
+        #    re-stamped every tick forever (Bug 3).
+        for agent_id, worktree_path, shared_dir_name in live_agents:
+            view_notes_dir = worktree_path / shared_dir_name / "notes"
+            manifest = load_manifest(public_root, agent_id, kind="notes")
+            harvest_drafts(view_notes_dir, shared_notes_dir, manifest)
+            save_manifest(public_root, agent_id, manifest, kind="notes")
+
+        # 2. Verify + stamp every shared note's evidence against the attempt
+        #    store, now that this pass's drafts are folded in.
+        note_paths = _iter_user_note_files(shared_notes_dir)
+        notes: list[tuple[Path, dict[str, Any]]] = []
+        verdicts: dict[Path, Verdict] = {}
+        for note_path in note_paths:
+            meta, _ = _parse_frontmatter(note_path.read_text())
+            notes.append((note_path, meta))
+            verdicts[note_path] = verify_note(note_path, coral_dir)
+        stamp_verdicts(shared_notes_dir, verdicts)
+
+        # 3. Group + rank once over the now-harvested, now-stamped notes.
+        groups = group_notes(notes, verdicts, coral_dir=coral_dir)
+        ranked_groups = rank_groups(groups, verdicts)
+
+        # 4. Regenerate every live agent's served view from shared state.
+        for agent_id, worktree_path, shared_dir_name in live_agents:
+            view_dir = worktree_path / shared_dir_name
+            generate_notes_view(
+                view_dir / "notes", shared_notes_dir, public_root, agent_id, verdicts, ranked_groups
+            )
+            generate_skills_view(view_dir / "skills", shared_skills_dir, public_root, agent_id)
+
     # ------------------------------------------------------------------
     # Migration
     # ------------------------------------------------------------------
@@ -2468,6 +2652,12 @@ class AgentManager:
