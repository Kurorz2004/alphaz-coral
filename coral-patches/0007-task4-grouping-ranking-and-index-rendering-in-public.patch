+        "creator: agent-1\ncreated: 2026-03-12T00:00:00-00:00\n",
+        body="# Representative note\nBody.\n",
+    )
+    member = _write_note_file(
+        notes_dir / "member.md",
+        "creator: agent-2\ncreated: 2026-03-10T00:00:00-00:00\n",
+        body="# See-also note\nBody.\n",
+    )
+    refuted_note = _write_note_file(
+        notes_dir / "refuted.md",
+        "creator: agent-3\ncreated: 2026-03-09T00:00:00-00:00\n",
+        body="# Refuted note\nBody.\n",
+    )
+    failed_note = _write_note_file(
+        notes_dir / "failed.md",
+        "creator: agent-4\ncreated: 2026-03-08T00:00:00-00:00\n",
+        body="# Failed note\nBody.\n",
+    )
+
+    groups = [
+        Group(representative=rep, see_also=[member], recency=datetime(2026, 3, 12, tzinfo=UTC)),
+        Group(representative=refuted_note, see_also=[], recency=datetime(2026, 3, 9, tzinfo=UTC)),
+        Group(representative=failed_note, see_also=[], recency=datetime(2026, 3, 8, tzinfo=UTC)),
+    ]
+    verdicts = {
+        rep: Verdict(verified=True, confidence="high", reason="ok"),
+        member: Verdict(verified=True, confidence="high", reason="ok"),
+        refuted_note: Verdict(verified=True, confidence="low", reason="self-declared refuted"),
+        failed_note: Verdict(verified=False, confidence="low", reason="score mismatch"),
+    }
+
+    ranked = rank_groups(groups, verdicts)
+    text = render_index(ranked, verdicts, base_dir=notes_dir)
+
+    # Generated-file header, agents shouldn't hand-edit it.
+    assert "GENERATED" in text
+    assert "hand-edit" in text.lower()
+
+    # Status column, wording aligned with format_notes_list's tokens.
+    assert "[verified/high]" in text
+    assert "[refuted]" in text
+    assert "[failed]" in text
+
+    # See-also is an indented subline directly under its representative;
+    # refuted/failed land at the bottom, mirroring the ranking.
+    idx_rep = text.index("Representative note")
+    idx_member = text.index("See-also note")
+    idx_refuted = text.index("Refuted note")
+    idx_failed = text.index("Failed note")
+    assert idx_rep < idx_member < idx_refuted < idx_failed
+
+    seealso_line = next(ln for ln in text.splitlines() if "See-also note" in ln)
+    assert seealso_line.startswith("    ")
+    # Link is relative to base_dir (member.md lives directly in notes_dir),
+    # POSIX-style, never the absolute filesystem path.
+    assert "(member.md)" in seealso_line
+    assert str(member) not in text
+
+    # Deterministic: same input -> byte-identical output.
+    assert render_index(ranked, verdicts, base_dir=notes_dir) == text
+
+
+def test_render_index_missing_member_file_does_not_crash(tmp_path):
+    notes_dir = tmp_path / "public" / "notes"
+    rep = _write_note_file(
+        notes_dir / "rep.md",
+        "creator: agent-1\ncreated: 2026-03-12T00:00:00-00:00\n",
+        body="# Representative note\nBody.\n",
+    )
+    # A see-also member whose file was deleted/moved after grouping.
+    missing_member = notes_dir / "missing.md"
+    assert not missing_member.exists()
+
+    groups = [
+        Group(
+            representative=rep,
+            see_also=[missing_member],
+            recency=datetime(2026, 3, 12, tzinfo=UTC),
+        )
+    ]
+    verdicts = {rep: Verdict(verified=True, confidence="high", reason="ok")}
+
+    text = render_index(groups, verdicts, base_dir=notes_dir)
+
+    # Representative still renders normally.
+    assert "Representative note" in text
+    # Missing member degrades to its filename stem instead of crashing.
+    assert "missing" in text
+    assert "(missing.md)" in text
