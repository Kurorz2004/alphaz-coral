+def test_orchestrator_happy_path_consolidates_and_archives(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    public_root, shared_notes_dir = _public_dirs(tmp_path)
+
+    a = _write_note_file(
+        shared_notes_dir / "a.md",
+        f"creator: island-0-agent-1\ncreated: 2026-03-10T00:00:00-00:00\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# A\nFinding A.\n",
+    )
+    b = _write_note_file(
+        shared_notes_dir / "b.md",
+        f"creator: island-0-agent-2\ncreated: 2026-03-11T00:00:00-00:00\nevidence:\n  attempt: {_SHORT_HASH_2}\n",
+        body="# B\nFinding B.\n",
+    )
+    group = Group(representative=b, see_also=[a], recency=datetime(2026, 3, 11, tzinfo=UTC))
+
+    llm_output = (
+        "TITLE: Combined finding\n"
+        "ATTEMPTS:\n"
+        f"- {_FULL_HASH}: 0.42\n"
+        f"- {_FULL_HASH_2}: 0.55\n"
+        "BODY:\n"
+        "Both notes agree the change improves score.\n"
+    )
+    calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        calls.append(prompt)
+        return llm_output
+
+    result = run_consolidation_pass(
+        shared_notes_dir, tmp_path, [group], llm_call=fake_llm, public_root=public_root
+    )
+
+    assert result is True
+    assert len(calls) == 1
+
+    consolidated_files = list(shared_notes_dir.glob("consolidated-*.md"))
+    assert len(consolidated_files) == 1
+    note_text = consolidated_files[0].read_text()
+    meta, body_text = _parse_frontmatter(note_text)
+    assert meta["creator"] == CONSOLIDATOR_CREATOR
+    assert sorted(meta["consolidates"]) == ["a.md", "b.md"]
+    assert "Combined finding" in note_text
+    assert "Both notes agree the change improves score." in body_text
+
+    assert not a.exists()
+    assert not b.exists()
+
+    archive_dirs = list((public_root / "note_archive").iterdir())
+    assert len(archive_dirs) == 1
+    archived_files = sorted(p.name for p in archive_dirs[0].iterdir())
+    assert archived_files == ["a.md", "b.md"]
+
+    cache = load_consolidation_cache(public_root)
+    assert len(cache) == 1
+    entry = next(iter(cache.values()))
+    assert entry["status"] == "consolidated"
+    assert entry["note"] == consolidated_files[0].name
+
