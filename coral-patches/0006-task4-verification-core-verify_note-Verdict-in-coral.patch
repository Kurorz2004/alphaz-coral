+++ b/tests/test_publication_gate.py
@@ -11,7 +11,10 @@ from __future__ import annotations
 from pathlib import Path
 
 from coral.config import AgentConfig, CoralConfig, TaskConfig
+from coral.hub.attempts import write_attempt
 from coral.hub.notes import _parse_frontmatter, format_notes_list, list_notes, upsert_frontmatter
+from coral.hub.publication import verify_note
+from coral.types import Attempt
 
 # --------------------------------------------------------------------------- #
 # Task 1 — config flag
@@ -263,3 +266,269 @@ def test_format_notes_list_shows_unverified_status(tmp_path):
     formatted = format_notes_list(entries)
 
     assert formatted.endswith("[unverified]")
+
+
+# --------------------------------------------------------------------------- #
+# Task 3 — verify_note()
+# --------------------------------------------------------------------------- #
+
+_FULL_HASH = "7b1e4d001122334455667788990011223344aabb"
+_SHORT_HASH = _FULL_HASH[:12]
+
+
+def _make_attempt(
+    commit: str,
+    agent: str = "island-0-agent-2",
+    score: float | None = 0.42,
+    metadata: dict | None = None,
+) -> Attempt:
+    return Attempt(
+        commit_hash=commit,
+        agent_id=agent,
+        title="a change",
+        score=score,
+        status="improved" if score is not None else "pending",
+        parent_hash=None,
+        timestamp="2026-03-14T17:00:00-00:00",
+        metadata=metadata or {},
+    )
+
+
+def _write_note_file(path: Path, frontmatter: str, body: str = "# Title\nBody text.\n") -> Path:
+    _write_note(path, f"---\n{frontmatter}\n---\n\n{body}")
+    return path
+
+
+def test_verify_note_matching_creator_and_score_is_verified_high(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        f"claim: matmul tiling helps\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.4200\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+    assert "match" in verdict.reason
+
+
+def test_verify_note_no_evidence_is_unverifiable_medium(tmp_path):
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "synthesis.md",
+        "creator: island-0-agent-2\ntype: synthesis\nclaim: general pattern across attempts\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+    assert "no evidence cited" in verdict.reason
+
+
+def test_verify_note_wrong_creator_is_false_low(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-2", score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-9\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.4200\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is False
+    assert verdict.confidence == "low"
+    assert "island-0-agent-9" in verdict.reason
+    assert "island-0-agent-2" in verdict.reason
+
+
+def test_verify_note_mismatched_score_is_false_low(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.99\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is False
+    assert verdict.confidence == "low"
+    assert "0.99" in verdict.reason
+
+
+def test_verify_note_refuted_with_valid_evidence_stays_verified_but_low(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "status: refuted\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.4200\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "low"
+    assert "refuted" in verdict.reason
+
+
+def test_verify_note_unscored_attempt_is_unverifiable(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=None))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\nevidence:\n  attempt: " + _SHORT_HASH + "\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+
+
+def test_verify_note_short_hash_prefix_resolves_uniquely(tmp_path):
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    # A second, unrelated attempt with a different prefix must not interfere.
+    write_attempt(tmp_path, _make_attempt("ffffffff0000000000000000000000000000ff", score=0.1))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.4200\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+def test_verify_note_ambiguous_prefix_is_unverifiable(tmp_path):
+    prefix = "aaaaaaaaaaaa"  # 12 chars, shared by both full hashes below
+    write_attempt(tmp_path, _make_attempt(prefix + "1111111111111111111111111111", score=0.42))
+    write_attempt(tmp_path, _make_attempt(prefix + "2222222222222222222222222222", score=0.5))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\nevidence:\n  attempt: " + prefix + "\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+    assert "ambiguous" in verdict.reason or "not found" in verdict.reason
+
+
+def test_verify_note_no_frontmatter_block_is_unverifiable_medium(tmp_path):
+    # No leading '---' at all — never even looks like a frontmatter block.
+    note = tmp_path / "public" / "notes" / "a.md"
+    note.parent.mkdir(parents=True, exist_ok=True)
+    note.write_text("# Just a title\nNo frontmatter here, straight into the body.\n")
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+    assert "frontmatter" in verdict.reason
+
+
+def test_verify_note_unterminated_frontmatter_block_is_unverifiable_medium(tmp_path):
+    # Opens with '---' but never closes it — _parse_frontmatter can't find
+    # the block and verify_note must go through the real code path (not a
+    # direct _parse_frontmatter call) and still land on unverifiable/medium.
+    note = tmp_path / "public" / "notes" / "a.md"
+    note.parent.mkdir(parents=True, exist_ok=True)
+    note.write_text(
+        "---\ncreator: island-0-agent-2\nevidence:\n  attempt: " + _SHORT_HASH + "\n\n"
+        "# Title\nBody, but the frontmatter block was never closed.\n"
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+    assert "frontmatter" in verdict.reason
+
+
+def test_verify_note_mismatch_overrides_refuted_precedence(tmp_path):
+    # A genuinely wrong evidence.score must win over the self-declared
+    # "refuted" status: verified=False/low, NOT True/low. Otherwise a note
+    # could hide bogus evidence behind an honest-looking refuted label.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "status: refuted\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score: \"0.99\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is False
+    assert verdict.confidence == "low"
+
+
+def test_verify_note_tune_budget_class_with_real_score_is_unverifiable(tmp_path):
+    # Distinct from the unscored case: this attempt IS scored, but it's a
+    # tune sweep, not a real submission — must not be treated as evidence.
+    write_attempt(
+        tmp_path, _make_attempt(_FULL_HASH, score=0.42, metadata={"budget_class": "tune"})
+    )
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\nevidence:\n  attempt: " + _SHORT_HASH + "\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified == "unverifiable"
+    assert verdict.confidence == "medium"
+
+
+def test_verify_note_wrong_score_delta_does_not_affect_verdict(tmp_path):
+    # score_delta is a delta between two attempts, not a score against this
+    # one — it must never be checked, even when it's obviously wrong.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        "  score_delta: 999.0\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
+
+
+def test_verify_note_full_hash_citation_resolves_exact_match(tmp_path):
+    # Cite the full 40-char commit hash directly (not a short prefix) —
+    # exercises the exact-match path of _resolve_attempt_hash.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, score=0.42))
+    note = _write_note_file(
+        tmp_path / "public" / "notes" / "a.md",
+        "creator: island-0-agent-2\n"
+        "evidence:\n"
+        f"  attempt: {_FULL_HASH}\n"
+        "  score: \"0.4200\"\n",
+    )
+
+    verdict = verify_note(note, tmp_path)
+
+    assert verdict.verified is True
+    assert verdict.confidence == "high"
