+def test_orchestrator_archive_failure_rolls_back_and_preserves_other_group_cache(tmp_path, monkeypatch):
+    # Two members' worth of attempts, shared by both groups below.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    public_root, shared_notes_dir = _public_dirs(tmp_path)
+
+    # Group 1: consolidates cleanly and is processed FIRST.
+    ok_a = _write_note_file(
+        shared_notes_dir / "ok_a.md",
+        f"creator: island-0-agent-1\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# OK A\nFinding A.\n",
+    )
+    ok_b = _write_note_file(
+        shared_notes_dir / "ok_b.md",
+        f"creator: island-0-agent-2\nevidence:\n  attempt: {_SHORT_HASH_2}\n",
+        body="# OK B\nFinding B.\n",
+    )
+    ok_group = Group(representative=ok_b, see_also=[ok_a], recency=datetime.now(UTC))
+    ok_llm_output = (
+        "TITLE: OK combined\n"
+        "ATTEMPTS:\n"
+        f"- {_FULL_HASH}: 0.42\n"
+        f"- {_FULL_HASH_2}: 0.55\n"
+        "BODY:\n"
+        "Both notes agree.\n"
+    )
+
+    # Group 2: same shape, processed SECOND -- its archive step fails on its
+    # second member.
+    bad_a = _write_note_file(
+        shared_notes_dir / "bad_a.md",
+        f"creator: island-0-agent-1\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# BAD A\nFinding A2.\n",
+    )
+    bad_b = _write_note_file(
+        shared_notes_dir / "bad_b.md",
+        f"creator: island-0-agent-2\nevidence:\n  attempt: {_SHORT_HASH_2}\n",
+        body="# BAD B\nFinding B2.\n",
+    )
+    bad_group = Group(representative=bad_a, see_also=[bad_b], recency=datetime.now(UTC))
+    bad_llm_output = (
+        "TITLE: BAD combined\n"
+        "ATTEMPTS:\n"
+        f"- {_FULL_HASH}: 0.42\n"
+        f"- {_FULL_HASH_2}: 0.55\n"
+        "BODY:\n"
+        "Both notes agree.\n"
+    )
+
+    def fake_llm(prompt: str) -> str:
+        if "bad_a.md" in prompt or "bad_b.md" in prompt:
+            return bad_llm_output
+        return ok_llm_output
+
+    real_replace = os.replace
+
+    def failing_replace(src, dst, *args, **kwargs):
+        # Fail moving bad_b.md into note_archive/ specifically -- the
+        # SECOND member of bad_group (representative=bad_a is archived
+        # first, then bad_b fails). Every other os.replace call (including
+        # bad_a's own archive move, the rollback move back, the OK group's
+        # archive/publish, and the final cache write) goes through for real.
+        if Path(src).name == "bad_b.md" and "note_archive" in str(dst):
+            raise OSError("simulated cross-device failure")
+        return real_replace(src, dst, *args, **kwargs)
+
+    monkeypatch.setattr(os, "replace", failing_replace)
+
+    result = run_consolidation_pass(
+        shared_notes_dir,
+        tmp_path,
+        [ok_group, bad_group],
+        llm_call=fake_llm,
+        public_root=public_root,
+    )
+
+    # Does not raise (implicit -- reaching here at all proves it) and DOES
+    # report a consolidation happened, because ok_group succeeded.
+    assert result is True
+
+    # bad_group: rolled back -- both originals back in shared_notes_dir,
+    # nothing published, nothing left in note_archive for this group.
+    assert bad_a.exists()
+    assert bad_b.exists()
+    consolidated_files = {p.name for p in shared_notes_dir.glob("consolidated-*.md")}
+    assert len(consolidated_files) == 1  # only ok_group's
+
+    cache = load_consolidation_cache(public_root)
+    assert len(cache) == 2
+
+    statuses = {entry["status"] for entry in cache.values()}
+    assert statuses == {"consolidated", "failed"}
+    failed_entries = [e for e in cache.values() if e["status"] == "failed"]
+    assert failed_entries[0]["member_relpaths"] == ["bad_a.md", "bad_b.md"]
+    assert failed_entries[0]["note"] is None
+
+    # ok_group's cache entry -- processed BEFORE the failing group -- is
+    # still present and correct after the whole call.
+    consolidated_entries = [e for e in cache.values() if e["status"] == "consolidated"]
+    assert consolidated_entries[0]["member_relpaths"] == ["ok_a.md", "ok_b.md"]
+    assert consolidated_entries[0]["note"] in consolidated_files
+
