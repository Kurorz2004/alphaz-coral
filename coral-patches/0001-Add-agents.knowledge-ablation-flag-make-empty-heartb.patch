+def test_empty_heartbeat_list_is_honoured_only_without_protect(tmp_path):
+    """Regression: `agents.heartbeat: []` silently regrew reflect + consolidate.
+
+    ``write_*_heartbeat`` re-adds the protected actions when they are absent.
+    That turned Condition B ("disable all heartbeats") into a no-op. ``protect``
+    is the opt-out; without it CORAL still injects reflect/consolidate.
+    """
+    coral_dir = tmp_path
+    (coral_dir / "public").mkdir(parents=True)
+
+    write_agent_heartbeat(coral_dir, "a1", [])
+    write_global_heartbeat(coral_dir, [])
+    assert [a["name"] for a in read_agent_heartbeat(coral_dir, "a1")] == ["reflect"]
+    assert [a["name"] for a in read_global_heartbeat(coral_dir)] == ["consolidate"]
+
+    write_agent_heartbeat(coral_dir, "a1", [], protect=False)
+    write_global_heartbeat(coral_dir, [], protect=False)
+    assert read_agent_heartbeat(coral_dir, "a1") == []
+    assert read_global_heartbeat(coral_dir) == []
