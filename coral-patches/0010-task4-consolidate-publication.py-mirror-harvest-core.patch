+def _mirror_into_view(
+    view_dir: str | Path,
+    files: dict[str, bytes],
+    public_root: str | Path,
+    agent_id: str,
+    *,
+    kind: str,
+    unconditional: dict[str, bytes] | None = None,
+) -> None:
+    """Write ``files`` into ``view_dir`` and save the updated manifest.
+
+    Core shared by :func:`generate_notes_view` and
+    :func:`generate_skills_view`: both assemble ``files`` (view-relative
+    POSIX path -> content bytes, mirroring shared state) and hand the
+    write/guard/prune/manifest mechanics off to this function.
+
+    Every write goes through :func:`_write_if_changed` — tmp file +
+    ``os.replace`` in ``view_dir`` itself, never a directory swap (Docker
+    bind mounts don't see those) — skipped when the sha256 already
+    matches, so an unchanged pass touches no mtimes.
+
+    Three-way clobber-window guard, ``files`` only (``unconditional``
+    bypasses it — see below): a view copy is overwritten only when it's
+    absent, or its *current* on-disk sha256 equals either (a) the
+    manifest's previous-pass hash (framework-owned, unedited since) or (b)
+    the target hash about to be written (already in sync, e.g. this pass's
+    harvest just folded that edit into shared state). Otherwise the file
+    diverged from both — an agent edit landed in the window between
+    harvest and this call — and it's left untouched, its *previous*
+    manifest entry carried forward (or omitted, if none) rather than
+    overwritten with the hash of content we didn't actually write. That
+    carried-forward/absent entry is what makes the edit look like a draft
+    again next pass, so :func:`harvest_drafts`/:func:`harvest_skills` picks
+    it up instead of it being silently lost.
+
+    ``unconditional`` entries (the notes view's generated ``index.md``)
+    skip the guard — always written, always recorded — since their content
+    is wholly framework-owned and a view-side edit to them is meant to be
+    discarded, not treated as a draft.
+
+    A previous-manifest entry no longer in this pass's combined set
+    (``files`` + ``unconditional``) is deleted from the view, but only if
+    its on-disk sha256 still equals the manifest's recorded hash (unedited
+    since); an edited stale file is left alone as an ordinary draft, picked
+    up by the next pass's harvest.
+
+    Saves the agent's ``kind`` manifest (see :func:`load_manifest` /
+    :func:`save_manifest`) to exactly what was written/kept this pass.
+    """
+    view_dir = Path(view_dir)
+    manifest = load_manifest(public_root, agent_id, kind=kind)
+
+    new_manifest: dict[str, str] = {}
+    for rel, content_bytes in files.items():
+        dest = view_dir / rel
+        prev_hash = manifest.get(rel)
+        target_hash = _sha256_bytes(content_bytes)
+        current_hash = _sha256_file(dest) if dest.exists() else None
+        if current_hash is None or current_hash in (prev_hash, target_hash):
+            _write_if_changed(dest, content_bytes)
+            new_manifest[rel] = target_hash
+        elif prev_hash is not None:
+            new_manifest[rel] = prev_hash
+        # else: leave rel out of new_manifest entirely -- an edited/foreign
+        # file with no prior tracked hash stays a draft candidate every pass
+        # until harvest picks it up.
+
+    for rel, content_bytes in (unconditional or {}).items():
+        _write_if_changed(view_dir / rel, content_bytes)
+        new_manifest[rel] = _sha256_bytes(content_bytes)
+
+    for rel, old_hash in manifest.items():
+        if rel in new_manifest:
+            continue
+        stale = view_dir / rel
+        if stale.is_file() and _sha256_file(stale) == old_hash:
+            try:
+                stale.unlink()
+            except OSError:
+                pass
+
+    save_manifest(public_root, agent_id, new_manifest, kind=kind)
+
