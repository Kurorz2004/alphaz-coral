+# --------------------------------------------------------------------------- #
+# parse_consolidation_output()                                                #
+# --------------------------------------------------------------------------- #
+
+
+def test_parse_happy_path():
+    text = (
+        "TITLE: Merged finding on tiling\n"
+        "ATTEMPTS:\n"
+        f"- {_SHORT_HASH}: 0.42\n"
+        f"- {_SHORT_HASH_2}: 0.55\n"
+        "BODY:\n"
+        "Combined synthesis of both notes.\n"
+    )
+    parsed = parse_consolidation_output(text)
+    assert parsed is not None
+    title, attempts, body = parsed
+    assert title == "Merged finding on tiling"
+    assert attempts == [(_SHORT_HASH, 0.42), (_SHORT_HASH_2, 0.55)]
+    assert body == "Combined synthesis of both notes."
+
+
+def test_parse_missing_title_marker_is_none():
+    text = "ATTEMPTS:\n- h: 0.1\nBODY:\nSome body.\n"
+    assert parse_consolidation_output(text) is None
