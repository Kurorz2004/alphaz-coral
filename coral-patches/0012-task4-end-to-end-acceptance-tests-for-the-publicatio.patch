+def test_mid_pass_view_edit_during_stamp_survives_and_is_harvested_next_tick(tmp_path, monkeypatch):
+    """Reviewer lock-in: a genuine agent edit landing in the SERVED VIEW copy
+    of a note, in the window between harvest (step 1) and regenerate (step
+    4) -- here injected right after ``stamp_verdicts`` (step 2) runs, via
+    monkeypatch -- must survive that pass's regenerate untouched (the
+    three-way clobber guard in ``_mirror_into_view`` leaves a view file alone
+    once its on-disk hash diverges from both the manifest's prior hash and
+    the freshly-computed target hash), the manifest must still carry the
+    PRE-edit hash (neither the edit's hash nor the unwritten target's), and
+    the very next pass's harvest must pick the edit up as a fresh draft."""
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id = mgr.specs[0].agent_id
+    worktree = tmp_path / "agents" / agent1_id
+    mgr.handles = [_make_handle(agent1_id, worktree, tmp_path / "a1.log")]
+    (coral_dir / "public" / "notes").mkdir(parents=True)
+    (coral_dir / "public" / "attempts").mkdir(parents=True)
+    (worktree / ".claude" / "notes").mkdir(parents=True)
+    (worktree / ".claude" / "skills").mkdir(parents=True)
+
+    view_note = worktree / ".claude" / "notes" / "finding.md"
+    view_note.write_text("---\ncreator: agent-1\n---\n\n# Finding\nOriginal agent-authored note.\n")
+
+    mgr._run_publication_pass()  # tick 1: establishes the framework-owned baseline
+
+    public = coral_dir / "public"
+    baseline_manifest = load_manifest(public, agent1_id, kind="notes")
+    baseline_hash = baseline_manifest["finding.md"]
+
+    real_stamp_verdicts = stamp_verdicts
+
+    def _stamp_then_inject_mid_pass_edit(*args, **kwargs):
+        result = real_stamp_verdicts(*args, **kwargs)
+        # Simulate a genuine agent edit landing in the served VIEW copy,
+        # after this tick's harvest already ran but before regenerate --
+        # exactly the clobber window _mirror_into_view's guard exists for.
+        view_note.write_text(
+            "---\ncreator: agent-1\n---\n\n# Finding\nEDITED mid-pass, between harvest and regenerate.\n"
+        )
+        return result
+
+    monkeypatch.setattr("coral.agent.manager.stamp_verdicts", _stamp_then_inject_mid_pass_edit)
+
+    mgr._run_publication_pass()  # tick 2: the mid-pass edit lands during this tick's body
+
+    # The edit survives the regenerate step untouched.
+    assert "EDITED mid-pass" in view_note.read_text()
+
+    # The manifest still holds the PRE-edit hash -- neither the edit's hash
+    # nor the (unwritten) freshly-regenerated target hash.
+    manifest_after = load_manifest(public, agent1_id, kind="notes")
+    assert manifest_after["finding.md"] == baseline_hash
+
+    monkeypatch.undo()
+
+    mgr._run_publication_pass()  # tick 3: harvests the edit as a fresh draft
+
+    shared_note = public / "notes" / "finding.md"
+    assert "EDITED mid-pass" in shared_note.read_text()
