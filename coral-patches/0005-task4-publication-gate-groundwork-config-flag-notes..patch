@@ -162,6 +167,109 @@ def _parse_frontmatter(text: str) -> tuple[dict[str, Any], str]:
     return {}, text
 
 
+# A top-level frontmatter key: column-0, ``identifier:``. Deliberately does
+# NOT match indented lines, so a key of the same name nested inside another
+# mapping (e.g. ``verified:`` inside an ``evidence:`` block) is never mistaken
+# for a top-level key by :func:`upsert_frontmatter`.
+_TOP_LEVEL_KEY_RE = re.compile(r"^([A-Za-z_][A-Za-z0-9_-]*):")
+
+
+def _render_scalar_line(key: str, value: Any) -> str:
+    """Render one ``key: value`` frontmatter line for a scalar update.
+
+    String values are flattened to a single line (embedded newlines become
+    spaces — a frontmatter line must stay one line) and quoted only when the
+    value needs it, by delegating to ``yaml.safe_dump`` on the lone key/value
+    pair and keeping just that rendered line.
+    """
+    if isinstance(value, str):
+        value = value.replace("\r\n", " ").replace("\n", " ")
+    return yaml.safe_dump({key: value}).strip("\n") + "\n"
+
+
+def upsert_frontmatter(path: str | Path, updates: dict[str, Any]) -> bool:
+    """Insert or update top-level scalar keys in a note's YAML frontmatter.
+
+    Edits the raw frontmatter *text* line by line instead of parsing the
+    whole block and re-dumping it, so every line the caller didn't ask to
+    change — an ISO datetime, a quoted string, a flow-style list, a nested
+    ``evidence:`` mapping, a folded/literal block scalar — survives
+    byte-for-byte. Only *top-level* keys (column 0, matching
+    :data:`_TOP_LEVEL_KEY_RE`) are matched or written; supports scalar values
+    only (bool / str / timestamp string) — everything the publication gate
+    stamps (``coral_verified`` / ``coral_confidence`` / ``coral_checked_at`` /
+    ``coral_reason``).
+
+    For each key in ``updates``: if a top-level line for it already exists,
+    that line — plus any indented/continuation lines belonging to it (e.g. a
+    multiline block scalar) — is replaced with a single new line. If no such
+    key exists yet, the new line is appended at the end of the frontmatter
+    block, just before the closing ``---``. Every other line is left
+    untouched. Idempotent — calling this again with the same ``updates``
+    leaves the file's content unchanged.
+
+    Written atomically (tmp file in the same directory + ``os.replace``,
+    mirroring ``coral.hub.attempts._write_attempt_json``) so concurrent
+    readers never observe a partial write.
+
+    Returns ``False`` and touches nothing if ``path`` has no parseable
+    frontmatter block (no leading ``---`` delimiter pair) — there is nothing
+    safe to merge into.
+    """
+    path = Path(path)
+    text = path.read_text()
+    # Same block-detection _parse_frontmatter uses; also run it so a file
+    # whose frontmatter can't even survive the YAML/lenient fallback is
+    # treated the same way every reader treats it (never touched below).
+    _parse_frontmatter(text)
+    if not (text.startswith("---") and text.find("---", 3) != -1):
+        return False
+
+    lines = text.splitlines(keepends=True)
+    delim_idxs = [i for i, ln in enumerate(lines) if ln.rstrip("\r\n") == "---"]
+    if len(delim_idxs) < 2:
+        return False
+    start, end = delim_idxs[0], delim_idxs[1]
+    front_lines = list(lines[start + 1 : end])
+    rest_lines = lines[end:]  # closing '---' onward — never touched
+
+    for key, value in updates.items():
+        rendered = _render_scalar_line(key, value)
+        replaced = False
+        i = 0
+        while i < len(front_lines):
+            m = _TOP_LEVEL_KEY_RE.match(front_lines[i])
+            if m and m.group(1) == key:
+                j = i + 1
+                while j < len(front_lines) and not _TOP_LEVEL_KEY_RE.match(front_lines[j]):
+                    j += 1
+                front_lines[i:j] = [rendered]
+                replaced = True
+                break
+            i += 1
+        if not replaced:
+            front_lines.append(rendered)
+
+    new_text = "".join(lines[: start + 1] + front_lines + rest_lines)
+    if new_text == text:
+        return True
+
+    fd, tmp_path = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
+    try:
+        with os.fdopen(fd, "w") as f:
+            f.write(new_text)
+            f.flush()
+            os.fsync(f.fileno())
+        os.replace(tmp_path, path)
+    except Exception:
+        try:
+            os.unlink(tmp_path)
+        except OSError:
+            pass
+        raise
+    return True
+
+
