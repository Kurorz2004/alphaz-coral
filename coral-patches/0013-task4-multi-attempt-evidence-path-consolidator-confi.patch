+def _verify_note_multi_attempt(
+    attempts_list: list[Any],
+    meta: dict[str, Any],
+    coral_dir: str | Path,
+    island_id: str | int | None,
+) -> Verdict:
+    """The ``evidence.attempts`` (list) path of :func:`verify_note` — see its
+    docstring's "Multi-attempt path" section for the full predicate.
+    """
+    if not attempts_list:
+        return _unverifiable("no evidence cited")
+
+    any_unresolvable = False
+    for entry in attempts_list:
+        if not isinstance(entry, dict):
+            any_unresolvable = True
+            continue
+        raw = entry.get("attempt")
+        raw = str(raw).strip() if raw else ""
+        if not raw:
+            any_unresolvable = True
+            continue
+
+        commit_hash = _resolve_attempt_hash(coral_dir, raw, island_id)
+        if commit_hash is None:
+            any_unresolvable = True
+            continue
+
+        attempt = read_attempt(coral_dir, commit_hash, island_id=island_id)
+        if attempt is None or attempt.score is None or attempt.budget_class != BUDGET_CLASS_REAL:
+            any_unresolvable = True
+            continue
+
+        if "score" in entry:
+            raw_score = entry["score"]
+            try:
+                claimed = float(raw_score)
+            except (TypeError, ValueError):
+                return Verdict(
+                    verified=False,
+                    confidence="low",
+                    reason=f"evidence.attempts entry {raw!r} score={raw_score!r} is not a number",
+                )
+            if abs(claimed - attempt.score) > _SCORE_TOLERANCE:
+                return Verdict(
+                    verified=False,
+                    confidence="low",
+                    reason=(
+                        f"evidence.attempts entry {raw!r} score={claimed} does not match "
+                        f"attempt score {attempt.score}"
+                    ),
+                )
+
+    if any_unresolvable:
+        return _unverifiable(
+            "one or more evidence.attempts entries is absent, unscored, unresolvable/ambiguous, "
+            "or not real budget"
+        )
+
+    status = str(meta.get("status", "") or "").strip().lower()
+    if status == "refuted":
+        return Verdict(
+            verified=True,
+            confidence="low",
+            reason="evidence matches attempts; note self-declared refuted",
+        )
+
+    return Verdict(verified=True, confidence="high", reason="evidence matches attempts")
+
+
