index 0000000..3556f3c
--- /dev/null
+++ b/coral/hub/publication.py
@@ -0,0 +1,171 @@
+"""Verification predicate for the publication gate (``agents.publication_gate``).
+
+A note makes a claim and cites the graded attempt (``evidence.attempt``) that
+backs it. This module answers one question, purely: *does the evidence in the
+note's frontmatter actually match the attempt it cites?* It never writes
+anything, never calls an LLM, and never hardcodes a runtime-specific path
+(``.claude``, ``.codex``, ...) — everything is parameterized by ``coral_dir``.
+
+:func:`verify_note` returns a :class:`Verdict`. A later task (the wiring/pass
+that actually stamps frontmatter) calls this and writes the result back via
+``coral.hub.notes.upsert_frontmatter`` as ``coral_verified`` /
+``coral_confidence`` / ``coral_reason`` (+ its own ``coral_checked_at``
+timestamp — not produced here, since this function is a pure, deterministic
+predicate). This module is inert until ``agents.publication_gate`` is true;
+nothing here reads that config flag — the caller decides whether to invoke it.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Literal
+
+from coral.hub.attempts import _attempts_dir, read_attempt
+from coral.hub.notes import _parse_frontmatter
+from coral.types import BUDGET_CLASS_REAL
+
+# The evidence keys that must equal Attempt.score (within tolerance) when
+# present. ``score_delta`` is deliberately excluded — it's a delta between two
+# attempts, not a score, and can't be checked against a single Attempt.
+_SCORE_KEYS = ("score", "score_after", "final_score")
+
+# Absolute tolerance for comparing a quoted evidence score against
+# Attempt.score. Scores are floats round-tripped through string frontmatter
+# (e.g. "0.9752"); this absorbs formatting/precision noise without being loose
+# enough to paper over a genuinely wrong number.
+_SCORE_TOLERANCE = 5e-5
+
+Confidence = Literal["high", "medium", "low"]
+# True/False are real verdicts; "unverifiable" means "we couldn't check this,
+# don't demote it" (e.g. it cites an in-flight or unscored attempt).
+
+
+@dataclass(frozen=True)
+class Verdict:
+    """Result of :func:`verify_note`.
+
+    Field names map 1:1 onto the frontmatter keys the (later) stamping pass
+    writes: ``verified`` -> ``coral_verified``, ``confidence`` ->
+    ``coral_confidence``, ``reason`` -> ``coral_reason``.
+    """
+
+    verified: bool | Literal["unverifiable"]
+    confidence: Confidence
+    reason: str
+
+
+def _unverifiable(reason: str) -> Verdict:
+    return Verdict(verified="unverifiable", confidence="medium", reason=reason)
+
+
+def _resolve_attempt_hash(
+    coral_dir: str | Path, prefix: str, island_id: str | int | None
+) -> str | None:
+    """Resolve a (possibly short) cited hash to the full commit hash on disk.
+
+    Notes cite short hashes (typically 12 chars); attempt records are filed
+    as ``<full_commit_hash>.json``. Scans the attempts store for filenames
+    whose stem starts with ``prefix``. Exactly one match is required — zero
+    or an ambiguous prefix both return ``None`` rather than guessing.
+    """
+    prefix = str(prefix).strip()
+    if not prefix:
+        return None
+    attempts_dir = _attempts_dir(coral_dir, island_id)
+    matches = sorted(
+        {p.stem for p in attempts_dir.iterdir() if p.suffix == ".json" and p.stem.startswith(prefix)}
+    )
+    return matches[0] if len(matches) == 1 else None
+
+
+def verify_note(
+    note_path: str | Path,
+    coral_dir: str | Path,
+    island_id: str | int | None = None,
+) -> Verdict:
+    """Verify a note's cited evidence against the attempt store.
+
+    Predicate (short-circuits top to bottom):
+
+    1. No parseable frontmatter -> unverifiable/medium.
+    2. No ``evidence.attempt`` cited -> unverifiable/medium ("no evidence
+       cited") — a synthesis/open-question note isn't making a checkable
+       claim, that's not a failure.
+    3. Cited attempt can't be resolved to exactly one hash, is missing,
+       unscored (``score is None``), or not real budget
+       (``budget_class != "real"``) -> unverifiable/medium. An honest note
+       citing an in-flight attempt must not be demoted to "refuted".
+    4. ``creator`` != the attempt's ``agent_id`` -> False/low (someone
+       claiming credit for another agent's result).
+    5. Any of ``evidence.score`` / ``evidence.score_after`` /
+       ``evidence.final_score`` present and not numerically equal (within
+       ``5e-5``) to the attempt's score -> False/low. ``score_delta`` is
+       never checked (it's a delta, not a score). Keys that are absent pass
+       vacuously.
+    6. Otherwise the evidence checks out -> verified True. If the note
+       self-declared ``status: refuted``, that's respected as a *demotion*
+       (confidence "low", reason says so) rather than a falsification — an
+       honestly-refuted note is still verified, just lower-confidence.
+       Otherwise -> True/high.
+    """
+    note_path = Path(note_path)
+    try:
+        text = note_path.read_text()
+    except OSError as exc:
+        return _unverifiable(f"could not read note: {exc}")
+
+    meta, _ = _parse_frontmatter(text)
+    if not meta:
+        return _unverifiable("no parseable frontmatter")
+
+    evidence = meta.get("evidence")
+    evidence = evidence if isinstance(evidence, dict) else {}
+    attempt_ref = evidence.get("attempt")
+    if not attempt_ref:
+        return _unverifiable("no evidence cited")
+
+    commit_hash = _resolve_attempt_hash(coral_dir, str(attempt_ref), island_id)
+    if commit_hash is None:
+        return _unverifiable(f"cited attempt {attempt_ref!r} not found or ambiguous")
+
+    attempt = read_attempt(coral_dir, commit_hash, island_id=island_id)
+    if attempt is None or attempt.score is None or attempt.budget_class != BUDGET_CLASS_REAL:
+        return _unverifiable(f"cited attempt {attempt_ref!r} is absent, unscored, or not real budget")
+
+    creator = str(meta.get("creator", "") or "").strip()
+    if creator != attempt.agent_id:
+        return Verdict(
+            verified=False,
+            confidence="low",
+            reason=f"creator {creator!r} does not match attempt agent {attempt.agent_id!r}",
+        )
+
+    for key in _SCORE_KEYS:
+        if key not in evidence:
+            continue
+        raw = evidence[key]
+        try:
+            claimed = float(raw)
+        except (TypeError, ValueError):
+            return Verdict(
+                verified=False,
+                confidence="low",
+                reason=f"evidence.{key}={raw!r} is not a number",
+            )
+        if abs(claimed - attempt.score) > _SCORE_TOLERANCE:
+            return Verdict(
+                verified=False,
+                confidence="low",
+                reason=f"evidence.{key}={claimed} does not match attempt score {attempt.score}",
+            )
+
+    status = str(meta.get("status", "") or "").strip().lower()
+    if status == "refuted":
+        return Verdict(
+            verified=True,
+            confidence="low",
+            reason="evidence matches attempt; note self-declared refuted",
+        )
+
+    return Verdict(verified=True, confidence="high", reason="evidence matches attempt")
diff --git a/tests/test_publication_gate.py b/tests/test_publication_gate.py
index 9c3fad7..ab060a2 100644
