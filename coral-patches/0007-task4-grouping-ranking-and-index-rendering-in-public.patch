+# --------------------------------------------------------------------------- #
+# Grouping (anti-redundancy) + ranking + index rendering                      #
+# --------------------------------------------------------------------------- #
+#
+# Downstream of verify_note: a later pass calls verify_note() once per note,
+# then group_notes()/rank_groups()/render_index() to decide what the served
+# index.md looks like. Nothing here writes, calls an LLM, or hardcodes a
+# runtime-specific path, matching the rest of this module.
+
+
+@dataclass(frozen=True)
+class Group:
+    """A cluster of notes that mechanically make the same claim.
+
+    ``representative`` is the best member to serve in the index; ``see_also``
+    are the rest, most-relevant first (same ordering rule as representative
+    selection). ``recency`` is the representative's sort datetime
+    (frontmatter date, mtime fallback — see ``coral.hub.notes._sort_key``),
+    cached here so :func:`rank_groups` and :func:`render_index` don't need to
+    re-stat/re-parse the note file.
+    """
+
+    representative: Path
+    see_also: list[Path]
+    recency: datetime
+
+
+def _verified_rank(verified: bool | Literal["unverifiable"]) -> int:
+    """Order verdicts for representative selection: True > "unverifiable" > False."""
+    if verified is True:
+        return 0
+    if verified == "unverifiable":
+        return 1
+    return 2
+
+
+def _tag_set(meta: dict[str, Any]) -> set[str]:
+    tags = meta.get("tags")
+    if isinstance(tags, list):
+        return {str(t).strip() for t in tags if str(t).strip()}
+    if tags:
+        return {s.strip() for s in str(tags).split(",") if s.strip()}
+    return set()
+
+
+def _cited_attempt_key(
+    meta: dict[str, Any], coral_dir: str | Path | None, island_id: str | int | None
+) -> str | None:
+    """The value Rule 1 compares: the resolved full hash, else the raw citation."""
+    evidence = meta.get("evidence")
+    evidence = evidence if isinstance(evidence, dict) else {}
+    raw = evidence.get("attempt")
+    raw = str(raw).strip() if raw else ""
+    if not raw:
+        return None
+    if coral_dir is not None:
+        resolved = _resolve_attempt_hash(coral_dir, raw, island_id)
+        if resolved is not None:
+            return resolved
+    return raw
+
+
+def group_notes(
+    notes: list[tuple[str | Path, dict[str, Any]]],
+    verdicts: dict[Path, Verdict],
+    coral_dir: str | Path | None = None,
+    island_id: str | int | None = None,
+) -> list[Group]:
+    """Cluster notes that mechanically make the same claim (connected components).
+
+    ``notes`` is ``[(note_path, meta), ...]`` where ``meta`` is the frontmatter
+    dict the caller already parsed (e.g. via ``_parse_frontmatter`` — the same
+    parse used to drive ``verify_note``), so no note is re-read here. ``verdicts``
+    maps each note path to the :class:`Verdict` :func:`verify_note` returned
+    for it.
+
+    Two notes merge (transitively) if either:
+      - Rule 1: they cite the same attempt — compared as the resolved full
+        commit hash when ``coral_dir`` is given and the citation resolves to
+        exactly one attempt, else the raw cited string.
+      - Rule 2: both have non-empty ``tags`` and the Jaccard overlap of their
+        tag sets is >= 0.5.
+    """
+    paths = [Path(p) for p, _ in notes]
+    metas = [m for _, m in notes]
+    verdict_map = {Path(k): v for k, v in verdicts.items()}
+    n = len(paths)
+
+    parent = list(range(n))
+
+    def find(i: int) -> int:
+        while parent[i] != i:
+            parent[i] = parent[parent[i]]
+            i = parent[i]
+        return i
+
+    def union(i: int, j: int) -> None:
+        ri, rj = find(i), find(j)
+        if ri != rj:
+            parent[ri] = rj
+
+    attempt_keys = [_cited_attempt_key(m, coral_dir, island_id) for m in metas]
+    tag_sets = [_tag_set(m) for m in metas]
+
+    for i in range(n):
+        for j in range(i + 1, n):
+            if attempt_keys[i] is not None and attempt_keys[i] == attempt_keys[j]:
+                union(i, j)
+                continue
+            if tag_sets[i] and tag_sets[j]:
+                # Case-sensitive set comparison, consistent with notes.py conventions
+                # (e.g. exact `creator` equality) — tags aren't casefolded before compare.
+                overlap = len(tag_sets[i] & tag_sets[j]) / len(tag_sets[i] | tag_sets[j])
+                if overlap >= 0.5:
+                    union(i, j)
+
+    def recency(i: int) -> datetime:
+        try:
+            mtime = os.path.getmtime(paths[i])
+        except OSError:
+            mtime = None
+        return _sort_key({"date": str(metas[i].get("created", "") or ""), "_mtime": mtime})
+
+    def sort_key(i: int) -> tuple[int, float, str]:
+        verdict = verdict_map.get(paths[i])
+        rank = _verified_rank(verdict.verified if verdict else "unverifiable")
+        return (rank, -recency(i).timestamp(), str(paths[i]))
+
+    components: dict[int, list[int]] = {}
+    for i in range(n):
+        components.setdefault(find(i), []).append(i)
+
+    groups: list[Group] = []
+    for idxs in components.values():
+        ordered = sorted(idxs, key=sort_key)
+        rep_idx = ordered[0]
+        groups.append(
+            Group(
+                representative=paths[rep_idx],
+                see_also=[paths[i] for i in ordered[1:]],
+                recency=recency(rep_idx),
+            )
+        )
+    return groups
+
+
+def _tier(verdict: Verdict | None) -> int:
+    """Serving tier: 1 verified/high, 2 unverifiable, 3 verified/low (self-refuted), 4 failed."""
+    if verdict is None or verdict.verified == "unverifiable":
+        return 2
+    if verdict.verified is True:
+        return 1 if verdict.confidence == "high" else 3
+    return 4
+
+
+def rank_groups(groups: list[Group], verdicts: dict[Path, Verdict]) -> list[Group]:
+    """Order groups for serving: by tier (see :func:`_tier`), most-recent first within a tier."""
+    verdict_map = {Path(k): v for k, v in verdicts.items()}
+
+    def key(g: Group) -> tuple[int, float]:
+        return (_tier(verdict_map.get(g.representative)), -g.recency.timestamp())
+
+    return sorted(groups, key=key)
+
+
+_STATUS_LABELS = {1: "verified/high", 2: "unverified", 3: "refuted", 4: "failed"}
+
+
+def _status_label(verdict: Verdict | None) -> str:
+    """Status column wording for the served index: verified/high, unverified,
+    refuted, failed.
+
+    Deliberately *not* the same vocabulary as ``notes._publication_status_token``
+    (which only distinguishes verified/refuted): the index needs a finer split
+    within "verified True" so an honestly self-declared-refuted note whose
+    evidence still checks out (tier 3, "refuted") reads differently from a
+    note that genuinely failed verification (tier 4, "failed") — see
+    :func:`_tier`.
+    """
+    return _STATUS_LABELS[_tier(verdict)]
+
+
+_INDEX_HEADER = (
+    "<!-- GENERATED by the publication gate (agents.publication_gate). "
+    "Do not hand-edit this file — the next verification pass regenerates it "
+    "and any manual edits will be lost. -->\n"
+    "# Notes Index"
+)
+
+
+def _read_note_for_index(path: Path) -> dict[str, Any]:
+    """Parse a note file for index rendering, degrading gracefully if unreadable.
+
+    Mirrors verify_note's defensive posture on unreadable files: a note that
+    goes missing between grouping and rendering (deleted, moved, whatever)
+    must not crash the index — it falls back to the file's stem as the title
+    with no date/creator, rather than letting ``FileNotFoundError`` propagate.
+    """
+    try:
+        return _parse_note_file(path)
+    except OSError:
+        return {"title": path.stem, "date": "", "creator": ""}
+
+
+def _relative_link(path: Path, base_dir: Path) -> str:
+    """POSIX-style path to ``path``, relative to ``base_dir`` — never absolute."""
+    return Path(os.path.relpath(path, base_dir)).as_posix()
+
+
+def render_index(ranked_groups: list[Group], verdicts: dict[Path, Verdict], base_dir: str | Path) -> str:
+    """Render the served ``index.md`` content for a publication-gated notes tree.
+
+    ``base_dir`` is the directory ``index.md`` itself will live in (the served
+    notes view root). Every see-also link is rendered as a POSIX-style path
+    *relative to* ``base_dir`` (``os.path.relpath`` + forward slashes) —
+    never an absolute filesystem path, so the generated file stays portable
+    across machines/checkouts/runtimes.
+
+    One line per group representative — date, title, creator, status — with
+    the group's remaining members rendered as indented "see also" sublines
+    directly under it, linking their actual (relative) file paths. Renders
+    ``ranked_groups`` in the order given, so call :func:`rank_groups` first to
+    put refuted/failed entries last. A note file that's gone missing since
+    grouping degrades gracefully instead of raising — see
+    :func:`_read_note_for_index`. Deterministic: the same
+    ``ranked_groups``/``verdicts``/``base_dir`` (and unchanged note files on
+    disk) always produce the same bytes.
+    """
+    verdict_map = {Path(k): v for k, v in verdicts.items()}
+    base_dir = Path(base_dir)
+    lines = [_INDEX_HEADER, ""]
+    for group in ranked_groups:
+        rep = _read_note_for_index(group.representative)
+        status = _status_label(verdict_map.get(group.representative))
+        date = rep.get("date", "") or ""
+        creator = rep.get("creator") or UNATTRIBUTED_CREATOR
+        lines.append(f"- [{date}] {rep['title']} ({creator}) [{status}]")
+        for member_path in group.see_also:
+            member = _read_note_for_index(member_path)
+            link = _relative_link(member_path, base_dir)
+            lines.append(f"    - see also: [{member['title']}]({link})")
+    return "\n".join(lines) + "\n"
