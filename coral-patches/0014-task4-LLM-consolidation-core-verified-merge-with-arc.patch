+"""Tests for the LLM note consolidation core: primitives (prompt/parse/
+group-id/cache) and the :func:`run_consolidation_pass` orchestrator in
+``coral.hub.consolidation``.
+
+A real LLM is never invoked here -- every orchestrator test injects a plain
+lambda/closure as ``llm_call``, and the autouse ``_forbid_real_llm_call``
+fixture monkeypatches :func:`coral.hub.consolidation.default_llm_call` to
+raise, so any accidental code path reaching for the real thing fails loudly.
+
+Fixture helpers (``_make_attempt`` / ``_write_note_file`` / ``_note_and_meta``
+/ ``_public_dirs``) mirror ``tests/test_gate_consolidation.py`` (itself
+mirroring ``tests/test_publication_gate.py``) so the suites read the same
+way; kept local since this file must not depend on their internals shifting.
+"""
+
+from __future__ import annotations
+
+import os
+from datetime import UTC, datetime
+from pathlib import Path
+
+import pytest
+
+from coral.hub.attempts import write_attempt
+from coral.hub.consolidation import (
+    CONSOLIDATOR_CREATOR,
+    ConsolidationMember,
+    build_consolidation_prompt,
+    group_id_for,
+    load_consolidation_cache,
+    parse_consolidation_output,
+    run_consolidation_pass,
+    save_consolidation_cache,
+)
+from coral.hub.notes import _parse_frontmatter
+from coral.hub.publication import Group, _sha256_file
+from coral.types import Attempt
+
+# --------------------------------------------------------------------------- #
+# Fixture helpers (mirrors tests/test_gate_consolidation.py)                  #
+# --------------------------------------------------------------------------- #
+
+_FULL_HASH = "7b1e4d001122334455667788990011223344aabb"
+_SHORT_HASH = _FULL_HASH[:12]
+_FULL_HASH_2 = "9c2f5e112233445566778899001122334455bbcc"
+_SHORT_HASH_2 = _FULL_HASH_2[:12]
+
+
+def _make_attempt(
+    commit: str,
+    agent: str = "island-0-agent-2",
+    score: float | None = 0.42,
+    metadata: dict | None = None,
+) -> Attempt:
+    return Attempt(
+        commit_hash=commit,
+        agent_id=agent,
+        title="a change",
+        score=score,
+        status="improved" if score is not None else "pending",
+        parent_hash=None,
+        timestamp="2026-03-14T17:00:00-00:00",
+        metadata=metadata or {},
+    )
+
+
+def _write_note(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text)
+
+
+def _write_note_file(path: Path, frontmatter: str, body: str = "# Title\nBody text.\n") -> Path:
+    _write_note(path, f"---\n{frontmatter}\n---\n\n{body}")
+    return path
+
+
+def _note_and_meta(path: Path) -> tuple[Path, dict]:
+    meta, _ = _parse_frontmatter(path.read_text())
+    return path, meta
+
+
+def _public_dirs(tmp_path: Path) -> tuple[Path, Path]:
+    public_root = tmp_path / "public"
+    shared_notes_dir = public_root / "notes"
+    shared_notes_dir.mkdir(parents=True)
+    return public_root, shared_notes_dir
+
+
+@pytest.fixture(autouse=True)
+def _forbid_real_llm_call(monkeypatch):
+    """Safety net: nothing in this suite may ever reach the real LLM call."""
+
+    def _boom(*args, **kwargs):
+        raise AssertionError("default_llm_call must never be invoked by tests")
+
+    monkeypatch.setattr("coral.hub.consolidation.default_llm_call", _boom)
+
