+def test_run_publication_pass_settles_after_one_follow_up_with_a_real_note(tmp_path, monkeypatch):
+    """Bug 3 regression (reviewer-reproduced hot loop, 14+ consecutive
+    passes): once a real user note exists, harvest must record what it
+    reconciled (:func:`coral.hub.publication._harvest_from_view`'s
+    in-place manifest mutation, persisted via ``save_manifest`` before the
+    same pass's regenerate step) or the freshly-stamped shared copy looks
+    like a still-unsynced draft forever -- re-harvested every tick (wiping
+    the stamp), re-stamped, mtimes advance, the pre-pass signature never
+    stabilizes, and the full pass body runs on every monitor tick forever.
+
+    With the fix: one active pass, exactly one cheap follow-up, then stable
+    forever -- the stamp is never wiped or re-timestamped, the note lands
+    in the agent's manifest, and the agent's own view ends up holding the
+    stamped copy (not the pristine draft)."""
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id = mgr.specs[0].agent_id
+    worktree = tmp_path / "agents" / agent1_id
+    mgr.handles = [_make_handle(agent1_id, worktree, tmp_path / "a1.log")]
+    (coral_dir / "public" / "notes").mkdir(parents=True)
+    (coral_dir / "public" / "attempts").mkdir(parents=True)
+    (worktree / ".claude" / "notes").mkdir(parents=True)
+    (worktree / ".claude" / "skills").mkdir(parents=True)
+
+    view_note = worktree / ".claude" / "notes" / "finding.md"
+    view_note.write_text("---\ncreator: agent-1\n---\n\n# Finding\nA real, agent-authored note.\n")
+
+    calls: list[int] = []
+    real_do_pass = mgr._do_publication_pass
+
+    def _counting_do_pass():
+        calls.append(1)
+        real_do_pass()
+
+    monkeypatch.setattr(mgr, "_do_publication_pass", _counting_do_pass)
+
+    for _ in range(5):
+        mgr._run_publication_pass()
+
+    # (a) exactly one active pass + one follow-up -- every tick after that
+    # short-circuits at the signature guard, forever (not a hot loop).
