+def _publication_status_token(entry: dict[str, Any]) -> str:
+    """Terse ``[verified/high]`` / ``[unverified]`` / ``[refuted]`` suffix.
+
+    Only produced when the entry carries a ``coral_verified`` or
+    ``coral_confidence`` frontmatter field (stamped by the publication gate,
+    see ``agents.publication_gate``) — notes without either field get no
+    suffix, so plain/legacy notes render exactly as before.
+    """
+    has_verified = "coral_verified" in entry
+    has_confidence = "coral_confidence" in entry
+    if not has_verified and not has_confidence:
+        return ""
+    if not has_verified:
+        return " [unverified]"
+    label = "verified" if entry["coral_verified"] else "refuted"
+    confidence = entry.get("coral_confidence")
+    if confidence:
+        label = f"{label}/{confidence}"
+    return f" [{label}]"
+
+
