+    assert "finding.md" in manifest
+
+    # (d) the agent's own view copy ends up holding the stamped version,
+    # not the pristine pre-stamp draft.
+    view_text = view_note.read_text()
+    assert "coral_checked_at" in view_text
+    assert "coral_confidence" in view_text
+
