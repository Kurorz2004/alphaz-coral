+
+_ON_MARKER = "<!-- ON -->\n"
+_OFF_MARKER = "\n<!-- OFF -->\n"
+
+
+def _knowledge_blocks(enabled: bool) -> dict[str, str]:
+    """Load the ON or OFF variant of every knowledge-channel template block.
+
+    Each file in ``template/knowledge/`` holds both variants of one region of
+    ``coral.md.template``, separated by the ON/OFF markers. The ON text is the
+    verbatim text that lived inline in the template before ``agents.knowledge``
+    existed, so ``enabled=True`` reproduces upstream CORAL.md byte-for-byte.
+    """
+    blocks: dict[str, str] = {}
+    for path in _KNOWLEDGE_DIR.glob("*.md"):
+        raw = path.read_text()
+        if not raw.startswith(_ON_MARKER) or _OFF_MARKER not in raw:
+            raise ValueError(f"Malformed knowledge block: {path}")
+        on, off = raw[len(_ON_MARKER) :].split(_OFF_MARKER, 1)
+        blocks[path.stem] = on if enabled else off.rstrip("\n")
+    return blocks
 
 
