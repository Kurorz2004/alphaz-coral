+"""Tests for ``agents.knowledge`` — CORAL's notes/skills ablation switch.
+
+The load-bearing property is the *first* test: with ``knowledge=True`` the
+generated CORAL.md must be byte-for-byte what upstream generated before the
+flag existed. Otherwise the ablation's control condition is not a control.
+"""
+
+from __future__ import annotations
+
+import subprocess
+
+import pytest
+
+from coral.config import AgentConfig, CoralConfig, GraderConfig, HeartbeatActionConfig, TaskConfig
+from coral.hub.heartbeat import (
+    default_global_actions,
+    default_local_actions,
+    read_agent_heartbeat,
+    read_global_heartbeat,
+    write_agent_heartbeat,
+    write_global_heartbeat,
+)
+from coral.template.coral_md import generate_coral_md
+from coral.workspace.project import _build_island_subtree
+
+UPSTREAM_REF = "upstream-base"
+
+
+def _config(knowledge: bool = True, heartbeat: list | None = None) -> CoralConfig:
+    return CoralConfig(
+        task=TaskConfig(name="JSSP", description="minimise makespan", tips="be fast"),
+        grader=GraderConfig(entrypoint="x:Y", direction="maximize"),
+        agents=AgentConfig(
+            count=2,
+            knowledge=knowledge,
+            heartbeat=AgentConfig().heartbeat if heartbeat is None else heartbeat,
+        ),
+    )
+
+
+def _upstream_template() -> str:
+    """The pre-flag template, read straight out of git."""
+    return subprocess.run(
+        ["git", "show", f"{UPSTREAM_REF}:coral/template/coral.md.template"],
+        capture_output=True,
+        text=True,
+        check=True,
+    ).stdout
+
+
+def test_knowledge_on_renders_byte_identical_to_upstream():
+    """knowledge=True must reproduce upstream CORAL.md exactly.
+
+    Renders the *upstream* template with the same substitutions generate_coral_md
+    makes, and compares against our spliced render. Any drift in a knowledge
+    block silently changes the control condition of the Task 3 ablation, so this
+    is asserted on bytes, not on structure.
+    """
+    cfg = _config(knowledge=True)
+    ours = generate_coral_md(cfg, agent_id="captain-nemo", shared_dir=".claude")
+
