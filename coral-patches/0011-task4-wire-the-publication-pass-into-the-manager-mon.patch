+def test_raw_dir_and_notes_md_never_manifested_stamped_or_pruned(tmp_path):
+    """A top-level ``raw/`` dir and the legacy ``notes.md`` file are
+    consolidate-owned housekeeping, not user notes -- neither ever lands in
+    a view manifest, gets stamped, or gets pruned by a publication pass.
+    Both stay symlinks, consistent with the seeding rule, across a full
+    pass that also processes a genuine user note normally."""
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id = mgr.specs[0].agent_id
+
+    public = coral_dir / "public"
+    (public / "notes").mkdir(parents=True)
+    (public / "attempts").mkdir(parents=True)
+    (public / "skills").mkdir(parents=True)
+    (public / "notes" / "notes.md").write_text("legacy single-file notes\n")
+    (public / "notes" / "raw").mkdir()
+    (public / "notes" / "raw" / "capture.md").write_text("raw capture, never a user note\n")
+    (public / "notes" / "user-note.md").write_text(
+        "---\ncreator: agent-1\n---\n\n# Finding\nA real user note.\n"
+    )
+
+    agent1_worktree = tmp_path / "agents" / agent1_id
+    agent1_worktree.mkdir(parents=True)
+    setup_shared_state(agent1_worktree, coral_dir, ".claude", knowledge=True, publication_gate=True)
+
+    mgr.handles = [_make_handle(agent1_id, agent1_worktree, tmp_path / "a1.log")]
+
+    view_notes_dir = agent1_worktree / ".claude" / "notes"
+    assert (view_notes_dir / "notes.md").is_symlink()
+    assert (view_notes_dir / "raw").is_symlink()
+    assert (view_notes_dir / "raw").resolve() == (public / "notes" / "raw").resolve()
+    assert (view_notes_dir / "user-note.md").is_file()
+    assert not (view_notes_dir / "user-note.md").is_symlink()
+
+    mgr._run_publication_pass()
+
+    manifest = load_manifest(public, agent1_id, kind="notes")
+    assert "notes.md" not in manifest
+    assert "raw" not in manifest
+    assert not any(k.startswith("raw/") for k in manifest)
+
+    # Still symlinks after the pass -- never rewritten or pruned.
+    assert (view_notes_dir / "notes.md").is_symlink()
+    assert (view_notes_dir / "raw").is_symlink()
+    assert (public / "notes" / "notes.md").read_text() == "legacy single-file notes\n"
+    assert (public / "notes" / "raw" / "capture.md").read_text() == "raw capture, never a user note\n"
+
+    # Sanity check the pass actually ran and processed the real user note.
+    index_text = (view_notes_dir / "index.md").read_text()
+    assert "Finding" in index_text
