+@pytest.mark.parametrize("knowledge", [True, False])
+def test_worktree_does_not_advertise_ablated_dirs(tmp_path, knowledge):
+    """Regression: the worktree symlinks leaked the knowledge channel.
+
+    `setup_shared_state` linked every _SHARED_STATE_ITEMS entry unconditionally.
+    With knowledge off the targets do not exist, so `.claude/notes` and
+    `.claude/skills` became *dangling* symlinks — `ls .claude/` still showed the
+    agent a notes and a skills directory the ablation had deleted. Caught in a
+    live Condition A run, not by inspection.
+    """
+    coral_dir = tmp_path / ".coral"
+    public = coral_dir / "public"
+    public.mkdir(parents=True)
+    _build_island_subtree(coral_dir, public, tmp_path, [], knowledge=knowledge)
+    (coral_dir / "config_dir").write_text(str(tmp_path))
+
+    wt = tmp_path / "wt"
+    wt.mkdir()
+    setup_shared_state(wt, coral_dir, ".claude", knowledge=knowledge)
+
+    shared = wt / ".claude"
+    for item in ("notes", "skills", "roles", "agents"):
+        link = shared / item
+        assert link.exists() is knowledge, f".claude/{item} presence should track knowledge"
+        assert link.is_symlink() is knowledge, f".claude/{item} must not dangle"
+    # Attempt plumbing is untouched by the ablation.
+    for item in ("attempts", "logs", "heartbeat", "eval_logs"):
+        assert (shared / item).exists(), f".claude/{item} must survive"
+
+
+def test_restart_prompt_respects_knowledge_ablation():
+    """The restart prompt is a second channel into the agent, injected on every
+    respawn. It told Condition A agents to run `coral notes` and `coral skills`
+    and to "consolidate scattered notes" — commands with nothing behind them.
+    """
+    build = AgentManager._build_score_prompt
+    attempt = {"score": 0.7, "commit_hash": "abc123def456", "title": "t", "feedback": "f"}
+
+    class _Fake:
+        def __init__(self, knowledge):
+            self.config = _config(knowledge=knowledge)
+
+    on = build(_Fake(True), attempt, eval_count=3)
+    off = build(_Fake(False), attempt, eval_count=3)
+
+    for banned in ("coral notes", "coral skills", "scattered notes", "reusable skills"):
+        assert banned in on, f"control restart prompt should mention {banned!r}"
+        assert banned not in off, f"ablated restart prompt still mentions {banned!r}"
+    for kept in ("coral log -n 10", "coral eval --tune", "Keep working"):
+        assert kept in off, f"ablated restart prompt dropped {kept!r}"
+
+
 def test_knowledge_off_drops_note_writing_heartbeats():
     on, off = _config(True), _config(False)
     assert {a["name"] for a in default_local_actions(on)} == {"reflect", "pivot"}
