+def test_housekeeping_symlink_shared_across_agents_and_untouched_by_pass(tmp_path):
+    """A housekeeping aggregate (e.g. ``_connections.md``) is seeded as a
+    per-file symlink into shared state for every agent -- so an edit
+    through one agent's view is immediately visible through another
+    agent's view (same shared file, no pass required), and a full
+    publication pass leaves it completely alone afterwards: not harvested,
+    not stamped, not pruned, still a symlink in both views."""
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    agent1_id, agent2_id = (s.agent_id for s in mgr.specs)
+
+    public = coral_dir / "public"
+    (public / "notes").mkdir(parents=True)
+    (public / "attempts").mkdir(parents=True)
+    (public / "skills").mkdir(parents=True)
+    (public / "notes" / "_connections.md").write_text("# Connections\ninitial\n")
+
+    agent1_worktree = tmp_path / "agents" / agent1_id
+    agent2_worktree = tmp_path / "agents" / agent2_id
+    for wt in (agent1_worktree, agent2_worktree):
+        wt.mkdir(parents=True)
+        setup_shared_state(wt, coral_dir, ".claude", knowledge=True, publication_gate=True)
+
+    mgr.handles = [
+        _make_handle(agent1_id, agent1_worktree, tmp_path / "a1.log"),
+        _make_handle(agent2_id, agent2_worktree, tmp_path / "a2.log"),
+    ]
+
+    agent1_connections = agent1_worktree / ".claude" / "notes" / "_connections.md"
+    agent2_connections = agent2_worktree / ".claude" / "notes" / "_connections.md"
+    assert agent1_connections.is_symlink()
+    assert agent2_connections.is_symlink()
+
+    # Agent 1 appends through its own view.
+    with agent1_connections.open("a") as f:
+        f.write("agent-1's addition\n")
+
+    # Same shared file -- agent 2's view sees the edit immediately, no pass
+    # required, and the shared copy carries it too.
+    assert agent2_connections.read_text() == agent1_connections.read_text()
+    assert (public / "notes" / "_connections.md").read_text() == agent1_connections.read_text()
+    assert "agent-1's addition" in agent2_connections.read_text()
+
+    mgr._run_publication_pass()
+
+    # Untouched by the pass: no coral_* stamp fields, not in either agent's
+    # notes manifest, still a symlink in both views.
+    final_content = (public / "notes" / "_connections.md").read_text()
+    assert "coral_verified" not in final_content
+    assert "coral_confidence" not in final_content
+    assert "coral_checked_at" not in final_content
+    assert agent1_connections.is_symlink()
+    assert agent2_connections.is_symlink()
+
+    manifest1 = load_manifest(public, agent1_id, kind="notes")
+    manifest2 = load_manifest(public, agent2_id, kind="notes")
+    assert "_connections.md" not in manifest1
+    assert "_connections.md" not in manifest2
+
