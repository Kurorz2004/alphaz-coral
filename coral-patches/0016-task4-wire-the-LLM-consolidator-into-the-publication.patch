+def test_consolidation_settle_no_hot_loop_llm_called_once_per_member_set(tmp_path, monkeypatch):
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    _setup_two_agent_group(mgr, coral_dir)
+
+    llm_calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        llm_calls.append(prompt)
+        return _consolidation_response([(_FULL_HASH, 0.42), (_FULL_HASH_2, 0.55)])
+
+    mgr._gate_llm_call = fake_llm
+
+    do_pass_calls: list[int] = []
+    real_do_pass = mgr._do_publication_pass
+
+    def _counting_do_pass():
+        do_pass_calls.append(1)
+        real_do_pass()
+
+    monkeypatch.setattr(mgr, "_do_publication_pass", _counting_do_pass)
+
+    for _ in range(5):
+        mgr._run_publication_pass()
+
+    # Exactly one active pass (harvest + consolidate + regenerate) plus one
+    # cheap follow-up (the active pass's own writes moved the signature) --
+    # never a hot loop.
+    assert len(do_pass_calls) == 2
+    assert len(llm_calls) == 1
+
+    for _ in range(3):  # a few more ticks: must stay perfectly stable
+        mgr._run_publication_pass()
+    assert len(do_pass_calls) == 2
+    assert len(llm_calls) == 1
