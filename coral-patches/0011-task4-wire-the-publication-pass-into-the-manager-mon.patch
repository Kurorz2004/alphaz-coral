+def _seed_gated_notes_dir(src: Path, dst: Path) -> None:
+    """Seed a gated agent's ``notes/`` view (``publication_gate=True``) from shared state.
+
+    Called once, when ``dst`` doesn't exist yet (see the call site in
+    :func:`setup_shared_state`) -- ``src`` is the shared-state notes dir for
+    this island, already guaranteed to exist.
+
+    Per top-level entry in ``src``:
+
+    - A **user note** (``coral.hub.notes._is_user_note`` -- an ordinary
+      note file, or any subdirectory other than ``raw/``) is copied as a
+      real file/dir: the agent's local draft copy, harvested into shared
+      state and the view regenerated from it on each publication pass (see
+      ``coral.hub.publication``).
+    - A **housekeeping** entry (``notes.md``, any ``_``-prefixed aggregate
+      file, or the top-level ``raw/`` dir) is instead symlinked, per-entry,
+      straight into shared state -- so every agent keeps writing the SAME
+      shared file for these consolidate-owned aggregates, exactly the old
+      whole-directory-symlink semantics for that subset. This matters
+      because the publication pass never harvests housekeeping entries (see
+      ``coral.hub.publication.harvest_drafts``): a real per-agent copy would
+      silently diverge and collide via last-writer-wins the moment two
+      agents both touched it.
+
+    Known limitation (gate v1): a housekeeping file an agent creates
+    *after* this call (e.g. a brand-new ``_new-aggregate.md``) has no
+    shared counterpart yet to symlink to, so it stays a real, agent-local
+    file rather than becoming shared -- vanilla (non-gated) mode would have
+    shared it immediately, since ``notes/`` there is one directory symlink
+    covering any new file.
+    """
+    from coral.hub.notes import _is_user_note
+
+    dst.mkdir(parents=True, exist_ok=True)
+    for entry in sorted(src.iterdir()):
+        target = dst / entry.name
+        if _is_user_note(entry, src):
+            if entry.is_dir():
+                shutil.copytree(entry, target)
+            else:
+                shutil.copy2(entry, target)
+            continue
+        try:
+            rel = os.path.relpath(entry.resolve(), dst.resolve())
+            target.symlink_to(rel)
+        except (ValueError, OSError):
+            target.symlink_to(entry.resolve())
+
