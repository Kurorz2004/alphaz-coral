+# --------------------------------------------------------------------------- #
+# Harvest + serve: agent view <-> shared state                                #
+# --------------------------------------------------------------------------- #
+#
+# When the publication gate is on, notes/ and skills/ in an agent worktree are
+# real directories the manager GENERATES (not symlinks). Agents write freely
+# into them; the manager harvests their writes into shared state, verifies/
+# stamps, then regenerates each view. A per-agent manifest records what the
+# framework last wrote so agent writes are never clobbered.
+#
+# Pass order (every call site follows this, and the functions below are
+# designed so calling them in this order is the natural thing to do):
+#
+#   1. harvest_drafts() / harvest_skills() - fold agent writes sitting in the
+#      view into shared state, using the manifest from the *previous* pass to
+#      tell an agent draft from a framework-written file.
+#   2. stamp_verdicts()                    - verify_note() + write verdicts
+#      into the now-current shared notes.
+#   3. group_notes() / rank_groups()       - cluster + order the (now
+#      harvested + stamped) shared notes.
+#   4. generate_notes_view() /
+#      generate_skills_view()              - rebuild the view from shared
+#      state and save the new manifest for next pass.
+#
+# Harvest must always run before regenerate: regenerate treats shared state
+# as ground truth and overwrites the view from it, so any agent edit still
+# sitting only in the view would be lost if harvest hadn't already folded it
+# into shared state first.
+
+_MANIFEST_DIR = ".publication"
+
+
+def _manifest_path(public_root: str | Path, agent_id: str, *, kind: str = "notes") -> Path:
+    suffix = "" if kind == "notes" else f".{kind}"
+    return Path(public_root) / _MANIFEST_DIR / f"{agent_id}{suffix}.json"
+
+
+def load_manifest(public_root: str | Path, agent_id: str, *, kind: str = "notes") -> dict[str, str]:
+    """Load the per-agent harvest/serve manifest.
+
+    Maps view-relative POSIX path -> sha256 of the file content the
+    framework last wrote there. A missing manifest file (never written yet)
+    returns an empty dict — the first pass then treats every file currently
+    in the view as a potential agent draft (see :func:`harvest_drafts`),
+    which is exactly right on migration from the old symlink-based view: the
+    dir may already contain pre-existing shared content, and harvesting a
+    file that's already byte-identical in shared state is a no-op.
+    """
+    path = _manifest_path(public_root, agent_id, kind=kind)
+    if not path.exists():
+        return {}
+    try:
+        data = json.loads(path.read_text())
+    except (OSError, json.JSONDecodeError):
+        return {}
+    if not isinstance(data, dict):
+        return {}
+    return {str(k): str(v) for k, v in data.items()}
+
+
+def save_manifest(
+    public_root: str | Path, agent_id: str, manifest: dict[str, str], *, kind: str = "notes"
+) -> None:
+    """Save the per-agent manifest atomically (tmp file + ``os.replace``, same
+    dir). Skipped entirely when the content on disk already matches, so an
+    unchanged pass leaves the manifest file's mtime untouched too."""
+    path = _manifest_path(public_root, agent_id, kind=kind)
+    payload = json.dumps(manifest, indent=2, sort_keys=True) + "\n"
+    _write_if_changed(path, payload.encode("utf-8"))
+
+
+def _atomic_write_bytes(path: Path, data: bytes) -> None:
+    """Write ``data`` to ``path`` atomically: tmp file in the same directory,
+    then ``os.replace`` — same pattern as ``notes.upsert_frontmatter`` and
+    ``attempts._write_attempt_json``. Required (not a directory swap) so
+    Docker bind mounts always see the new content.
+    """
+    path.parent.mkdir(parents=True, exist_ok=True)
+    fd, tmp_path = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
+    try:
+        with os.fdopen(fd, "wb") as f:
+            f.write(data)
+            f.flush()
+            os.fsync(f.fileno())
+        os.replace(tmp_path, path)
+    except Exception:
+        try:
+            os.unlink(tmp_path)
+        except OSError:
+            pass
+        raise
+
+
+def _write_if_changed(path: Path, data: bytes) -> bool:
+    """Write ``data`` to ``path`` (atomically) only if it differs from what's
+    already there. Returns whether a write happened. Comparing by sha256
+    (rather than always writing) is what keeps an unchanged regenerate pass
+    from touching any mtimes or leaving tmp-file churn.
+    """
+    if path.exists():
+        try:
+            if _sha256_bytes(path.read_bytes()) == _sha256_bytes(data):
+                return False
+        except OSError:
+            pass
+    _atomic_write_bytes(path, data)
+    return True
+
+
+def _sha256_bytes(data: bytes) -> str:
+    return hashlib.sha256(data).hexdigest()
+
+
+def _sha256_file(path: Path) -> str | None:
+    try:
+        return _sha256_bytes(path.read_bytes())
+    except OSError:
+        return None
+
+
+# See-also stub: the framework appends this to a group representative's
+# *served view copy only* — shared notes (the canonical source) never carry
+# it. Delimited by exact marker lines so it can be stripped deterministically
+# before an edited representative is harvested back into shared state.
+_SEE_ALSO_START = "<!-- coral:see-also -->"
+_SEE_ALSO_END = "<!-- /coral:see-also -->"
+
+_SEE_ALSO_RE = re.compile(
+    r"\n*" + re.escape(_SEE_ALSO_START) + r".*?" + re.escape(_SEE_ALSO_END) + r"\n*",
+    re.DOTALL,
+)
+
+
+def _render_see_also_block(links: list[tuple[str, str]]) -> str:
+    lines = [_SEE_ALSO_START]
+    lines += [f"- see also: [{title}]({link})" for title, link in links]
+    lines.append(_SEE_ALSO_END)
+    return "\n".join(lines)
+
+
+def _append_see_also_stub(content: str, links: list[tuple[str, str]]) -> str:
+    """Append the see-also stub to a shared note's text for the view copy.
+
+    ``content`` is assumed to already end in a trailing newline (as note
+    files do); the stub is appended with exactly one blank line of
+    separation so :func:`strip_see_also_stub` can undo this exactly when
+    nothing else about the file changed.
+    """
+    return content.rstrip("\n") + "\n\n" + _render_see_also_block(links) + "\n"
+
+
+def strip_see_also_stub(content: str) -> str:
+    """Remove the framework-appended see-also stub (see
+    :func:`_append_see_also_stub`) from ``content``, if present.
+
+    A no-op on content that never had one. Used by :func:`harvest_drafts` so
+    the stub — which only belongs in the served view copy of a group
+    representative — never leaks into the shared, canonical copy of the
+    note when that file is harvested.
+    """
+    return _SEE_ALSO_RE.sub("\n", content)
+
+
+def harvest_drafts(
+    view_dir: str | Path, shared_notes_dir: str | Path, manifest: dict[str, str]
+) -> list[str]:
+    """Copy agent-authored/modified notes from the view into shared state.
+
+    Walks ``view_dir`` recursively for ``*.md`` files. A file is an *agent
+    draft* when its current sha256 is absent from, or differs from,
+    ``manifest`` (view-relative POSIX path -> sha256 the framework last
+    wrote there) — i.e. it's new, or the agent edited it since the
+    framework last wrote it. A file whose current hash matches its manifest
+    entry is framework-owned and untouched this pass — skipped entirely.
+
+    ``index.md`` is excluded unconditionally, anywhere it's found: it's a
+    generated file, and any agent edits to it are discarded (the next
+    regenerate pass overwrites it from :func:`render_index`).
+
+    Before copying a draft, the framework-appended see-also stub is
+    stripped (see :func:`strip_see_also_stub`) — shared notes never carry
+    it, even for a harvested copy of a group representative. If the
+    resulting content is already byte-identical to what's in
+    ``shared_notes_dir`` at that path, the write is skipped (this is what
+    makes harvesting a view that started as a plain copy of shared state —
+    the post-symlink-migration case — a no-op).
+
+    Returns the view-relative POSIX paths that were actually written into
+    ``shared_notes_dir`` this call.
+    """
+    view_dir = Path(view_dir)
+    shared_notes_dir = Path(shared_notes_dir)
+    harvested: list[str] = []
+    if not view_dir.is_dir():
+        return harvested
+
+    for path in sorted(view_dir.rglob("*.md")):
+        if not path.is_file() or path.name == "index.md":
+            continue
+        rel = path.relative_to(view_dir).as_posix()
+        current_hash = _sha256_file(path)
+        if current_hash is None or manifest.get(rel) == current_hash:
+            continue  # framework-owned and unmodified, or unreadable
+
+        try:
+            text = path.read_text()
+        except OSError:
+            continue
+        stripped = strip_see_also_stub(text)
+        dest_bytes = stripped.encode("utf-8")
+        dest = shared_notes_dir / rel
+        if dest.exists() and _sha256_file(dest) == _sha256_bytes(dest_bytes):
+            continue  # already identical in shared -> no-op
+
+        _atomic_write_bytes(dest, dest_bytes)
+        harvested.append(rel)
+
+    return harvested
+
+
+_VERDICT_FRONTMATTER_FIELDS = ("coral_verified", "coral_confidence", "coral_reason")
+
+
+def _coral_verified_value(verified: bool | Literal["unverifiable"]) -> bool | None:
+    """Map :attr:`Verdict.verified` onto the frontmatter value :func:`stamp_verdicts`
+    writes for ``coral_verified``.
+
+    True/False stamp literally. ``"unverifiable"`` stamps ``None`` (YAML
+    ``null``) — never the literal string ``"unverifiable"``: that string is
+    truthy, and ``notes._publication_status_token`` treats any *present*
+    ``coral_verified`` as a real verdict (``"verified"`` if truthy, else
+    ``"refuted"``), so writing the string would render an unverifiable note
+    as ``[verified/...]``.
+
+    ``notes._parse_note_file`` drops ``None``-valued trace fields when
+    building the entry dict ``list_notes()``/``format_notes_list()`` read
+    (``val not in (None, "", [], {})``), so a ``coral_verified: null`` is
+    indistinguishable from an absent ``coral_verified`` to the renderer —
+    exactly the ``[unverified]`` contract (``coral_verified`` absent,
+    ``coral_confidence`` present). ``upsert_frontmatter`` can only overwrite
+    a scalar value, not delete a key, so writing ``null`` is also how a
+    *stale* ``coral_verified: true``/``false`` left over from an earlier
+    pass gets cleared when a note's verdict later becomes unverifiable —
+    without needing a key-removal capability.
+    """
+    return None if verified == "unverifiable" else verified
+
+
+def stamp_verdicts(
+    shared_notes_dir: str | Path,
+    verdicts: dict[Path, Verdict],
+    *,
+    now: datetime | None = None,
+) -> list[Path]:
+    """Stamp :func:`verify_note` verdicts into shared source notes' frontmatter.
+
+    For each ``(note_path, verdict)`` pair (``note_path`` may be absolute, or
+    relative to ``shared_notes_dir`` — both resolve to the same file), maps
+    the :class:`Verdict` onto ``coral_verified`` (see
+    :func:`_coral_verified_value`) / ``coral_confidence`` / ``coral_reason``
+    and upserts it via ``notes.upsert_frontmatter`` — but ONLY when at least
+    one of those three values actually differs from what the note's
+    frontmatter already carries. ``upsert_frontmatter`` on its own is
+    idempotent for a byte-identical rewrite, but it would still stamp a
+    fresh ``coral_checked_at`` on every call; gating on an actual value
+    change is what keeps an unchanged note's ``coral_checked_at`` from
+    drifting forward on every pass.
+
+    Returns the paths actually rewritten.
+    """
+    shared_notes_dir = Path(shared_notes_dir)
+    now = now or datetime.now(UTC)
+    checked_at = now.isoformat()
+
+    changed: list[Path] = []
+    for raw_path, verdict in verdicts.items():
+        path = Path(raw_path)
+        if not path.is_absolute():
+            path = shared_notes_dir / path
+        if not path.is_file():
+            continue
+        try:
+            text = path.read_text()
+        except OSError:
+            continue
+        meta, _ = _parse_frontmatter(text)
+        if not meta:
+            continue
+
+        new_values = {
+            "coral_verified": _coral_verified_value(verdict.verified),
+            "coral_confidence": verdict.confidence,
+            "coral_reason": verdict.reason,
+        }
+        if all(meta.get(key) == value for key, value in new_values.items()):
+            continue  # nothing actually changed -> leave coral_checked_at alone too
+
+        new_values["coral_checked_at"] = checked_at
+        if upsert_frontmatter(path, new_values):
+            changed.append(path)
+    return changed
+
+
+def generate_notes_view(
+    view_dir: str | Path,
+    shared_notes_dir: str | Path,
+    public_root: str | Path,
+    agent_id: str,
+    verdicts: dict[Path, Verdict],
+    ranked_groups: list[Group],
+) -> None:
+    """Regenerate one agent's served notes view from shared state.
+
+    Call this only after harvest_drafts() -> stamp_verdicts() ->
+    group_notes()/rank_groups() have already run this pass against
+    ``shared_notes_dir`` (see the module-level pass-order note above) —
+    ``verdicts``/``ranked_groups`` are their output, and this function
+    treats ``shared_notes_dir`` as ground truth.
+
+    Writes, for every ``*.md`` file under ``shared_notes_dir``: a verbatim
+    copy at the same relative path under ``view_dir`` — except a group
+    representative (``group.representative`` for each group in
+    ``ranked_groups``), which additionally gets the see-also stub appended
+    (see :func:`strip_see_also_stub`), linking its group's other members by
+    path relative to ``view_dir``. Also writes ``view_dir/index.md`` via
+    :func:`render_index`, in ``ranked_groups`` order (call
+    :func:`rank_groups` first).
+
+    Every write goes through :func:`_write_if_changed` — tmp file +
+    ``os.replace`` in ``view_dir`` itself (never a directory swap — Docker
+    bind mounts don't see those), and skipped entirely when the sha256
+    already matches what's on disk, so an unchanged pass touches no mtimes.
+
+    Clobber-window guard: a view copy is only overwritten when it's absent,
+    or its *current* on-disk sha256 equals either (a) the manifest's
+    recorded hash from the *previous* pass (framework-owned, unedited since
+    then) or (b) the sha256 of the content about to be written (already in
+    sync — e.g. this same pass's ``harvest_drafts()`` just folded that exact
+    edit into ``shared_notes_dir``, so writing it back is a safe no-op).
+    Otherwise the view file diverged from both what we last wrote *and* what
+    we're about to write — an agent edit landed in the window between
+    harvest and this call — and it's left untouched, with its *previous*
+    manifest entry carried forward unchanged (or omitted, if it never had
+    one) instead of being overwritten with the hash of content we didn't
+    actually write. That's what makes the edit visible as a draft again
+    (mismatched against the carried-forward/absent manifest entry) and
+    harvested by the *next* pass's :func:`harvest_drafts`, rather than
+    silently destroyed and its loss masked by a manifest that claims the
+    framework wrote what's now on disk.
+
+    Files present in the agent's *notes* manifest (framework-generated last
+    pass) that are no longer part of this pass's generated set are deleted
+    from the view — but only when their current on-disk sha256 still equals
+    the manifest's recorded hash (the agent hasn't edited them since). An
+    agent-edited stale file is left alone; it becomes an ordinary agent
+    draft and is picked up by the next pass's :func:`harvest_drafts` instead
+    of being silently deleted.
+
+    Updates the agent's notes manifest to exactly the set of files
+    written/kept this pass (keyed by view-relative POSIX path) and saves it
+    atomically (see :func:`load_manifest`/:func:`save_manifest`).
+    """
+    view_dir = Path(view_dir)
+    shared_notes_dir = Path(shared_notes_dir)
+    public_root = Path(public_root)
+    view_dir.mkdir(parents=True, exist_ok=True)
+
+    manifest = load_manifest(public_root, agent_id, kind="notes")
+
+    # See-also links, keyed by the representative's path relative to
+    # shared_notes_dir. Values relative to shared_notes_dir equal the
+    # equivalent path relative to view_dir (the view mirrors shared state
+    # file-for-file), so no cross-directory relpath math is needed.
+    rep_links: dict[str, list[tuple[str, str]]] = {}
+    for group in ranked_groups:
+        if not group.see_also:
+            continue
+        try:
+            rep_rel = group.representative.relative_to(shared_notes_dir).as_posix()
+        except ValueError:
+            continue
+        links: list[tuple[str, str]] = []
+        for member in group.see_also:
+            try:
+                member_rel = member.relative_to(shared_notes_dir).as_posix()
+            except ValueError:
+                continue
+            title = _read_note_for_index(member).get("title") or member.stem
+            links.append((title, member_rel))
+        if links:
+            rep_links[rep_rel] = links
+
+    new_manifest: dict[str, str] = {}
+    if shared_notes_dir.is_dir():
+        for src in sorted(shared_notes_dir.rglob("*.md")):
+            if not src.is_file():
+                continue
+            rel = src.relative_to(shared_notes_dir).as_posix()
+            try:
+                content = src.read_text()
+            except OSError:
+                continue
+            links = rep_links.get(rel)
+            if links:
+                content = _append_see_also_stub(content, links)
+            content_bytes = content.encode("utf-8")
+
+            dest = view_dir / rel
+            prev_hash = manifest.get(rel)
+            target_hash = _sha256_bytes(content_bytes)
+            current_hash = _sha256_file(dest) if dest.exists() else None
+            if current_hash is None or current_hash in (prev_hash, target_hash):
+                _write_if_changed(dest, content_bytes)
+                new_manifest[rel] = target_hash
+            elif prev_hash is not None:
+                new_manifest[rel] = prev_hash
+            # else: leave rel out of new_manifest entirely -- an edited/
+            # foreign file with no prior tracked hash stays a draft
+            # candidate every pass until harvest_drafts() picks it up.
+
+    # base_dir=shared_notes_dir (not view_dir): the view mirrors
+    # shared_notes_dir's relative structure file-for-file, so the two
+    # produce identical relative-link strings, and this avoids re-keying the
+    # (shared-rooted) verdicts dict and ranked_groups paths.
+    index_text = render_index(ranked_groups, verdicts, base_dir=shared_notes_dir)
+    index_bytes = index_text.encode("utf-8")
+    _write_if_changed(view_dir / "index.md", index_bytes)
+    new_manifest["index.md"] = _sha256_bytes(index_bytes)
+
+    for rel, old_hash in manifest.items():
+        if rel in new_manifest:
+            continue
+        stale = view_dir / rel
+        if stale.is_file() and _sha256_file(stale) == old_hash:
+            try:
+                stale.unlink()
+            except OSError:
+                pass
+
+    save_manifest(public_root, agent_id, new_manifest, kind="notes")
+
+
+def harvest_skills(
+    view_skills_dir: str | Path, shared_skills_dir: str | Path, manifest: dict[str, str]
+) -> list[str]:
+    """Copy agent-written/changed skill files from the view into shared skills.
+
+    Skills are directories containing files (SKILL.md plus arbitrary
+    supporting files), so unlike :func:`harvest_drafts` this walks every
+    file recursively — not just ``*.md`` — and there is no ``index.md``
+    exclusion or see-also stripping (neither concept applies to skills).
+    Otherwise identical mechanics: a file whose current sha256 is absent
+    from or differs from ``manifest`` is an agent draft, copied atomically;
+    a draft that's already byte-identical in shared state is a no-op.
+
+    Returns the view-relative POSIX paths actually written into
+    ``shared_skills_dir`` this call.
+    """
+    view_skills_dir = Path(view_skills_dir)
+    shared_skills_dir = Path(shared_skills_dir)
+    harvested: list[str] = []
+    if not view_skills_dir.is_dir():
+        return harvested
+
+    for path in sorted(p for p in view_skills_dir.rglob("*") if p.is_file()):
+        rel = path.relative_to(view_skills_dir).as_posix()
+        current_hash = _sha256_file(path)
+        if current_hash is None or manifest.get(rel) == current_hash:
+            continue
+
+        try:
+            data = path.read_bytes()
+        except OSError:
+            continue
+        dest = shared_skills_dir / rel
+        if dest.exists() and _sha256_file(dest) == _sha256_bytes(data):
+            continue
+
+        _atomic_write_bytes(dest, data)
+        harvested.append(rel)
+
+    return harvested
+
+
+def generate_skills_view(
+    view_skills_dir: str | Path,
+    shared_skills_dir: str | Path,
+    public_root: str | Path,
+    agent_id: str,
+) -> list[str]:
+    """Harvest + mirror one agent's served skills view against shared skills.
+
+    No verify/group/rank/index for skills, so — unlike notes — harvest and
+    regenerate are one call: first harvests agent-written/changed files from
+    ``view_skills_dir`` into ``shared_skills_dir`` (see
+    :func:`harvest_skills`, using the ``"skills"`` manifest), then mirrors
+    ``shared_skills_dir`` back into ``view_skills_dir`` verbatim (every file,
+    any type, recursively) via the same atomic writer, the same
+    clobber-window guard, and the same prune rule as
+    :func:`generate_notes_view` (a stale/diverged view file is left
+    untouched — never overwritten or deleted — unless it's still unedited
+    since the framework wrote it; see that function's docstring for the
+    exact three-way rule).
+
+    Updates and saves the agent's skills manifest. Returns the view-relative
+    POSIX paths harvested from the view into shared state this call.
+    """
+    view_skills_dir = Path(view_skills_dir)
+    shared_skills_dir = Path(shared_skills_dir)
+    public_root = Path(public_root)
+    view_skills_dir.mkdir(parents=True, exist_ok=True)
+    shared_skills_dir.mkdir(parents=True, exist_ok=True)
+
+    manifest = load_manifest(public_root, agent_id, kind="skills")
+    harvested = harvest_skills(view_skills_dir, shared_skills_dir, manifest)
+
+    new_manifest: dict[str, str] = {}
+    for src in sorted(p for p in shared_skills_dir.rglob("*") if p.is_file()):
+        rel = src.relative_to(shared_skills_dir).as_posix()
+        try:
+            data = src.read_bytes()
+        except OSError:
+            continue
+
+        dest = view_skills_dir / rel
+        prev_hash = manifest.get(rel)
+        target_hash = _sha256_bytes(data)
+        current_hash = _sha256_file(dest) if dest.exists() else None
+        if current_hash is None or current_hash in (prev_hash, target_hash):
+            _write_if_changed(dest, data)
+            new_manifest[rel] = target_hash
+        elif prev_hash is not None:
+            new_manifest[rel] = prev_hash
+        # else: leave rel out of new_manifest -- edited/foreign file with no
+        # prior tracked hash stays a draft candidate until harvested.
+
+    for rel, old_hash in manifest.items():
+        if rel in new_manifest:
+            continue
+        stale = view_skills_dir / rel
+        if stale.is_file() and _sha256_file(stale) == old_hash:
+            try:
+                stale.unlink()
+            except OSError:
+                pass
+
+    save_manifest(public_root, agent_id, new_manifest, kind="skills")
+    return harvested
