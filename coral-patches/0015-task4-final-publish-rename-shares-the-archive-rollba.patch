@@ -716,6 +716,67 @@ def test_orchestrator_archive_failure_rolls_back_and_preserves_other_group_cache
     assert consolidated_entries[0]["note"] in consolidated_files
 
 
+def test_orchestrator_final_publish_failure_rolls_back_archived_members(tmp_path, monkeypatch):
+    # The archive moves succeed for both members; only the final rename of
+    # the temp note to consolidated-<group_id>.md fails.
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH, agent="island-0-agent-1", score=0.42))
+    write_attempt(tmp_path, _make_attempt(_FULL_HASH_2, agent="island-0-agent-2", score=0.55))
+    public_root, shared_notes_dir = _public_dirs(tmp_path)
+
+    a = _write_note_file(
+        shared_notes_dir / "a.md",
+        f"creator: island-0-agent-1\nevidence:\n  attempt: {_SHORT_HASH}\n",
+        body="# A\nFinding A.\n",
+    )
+    b = _write_note_file(
+        shared_notes_dir / "b.md",
+        f"creator: island-0-agent-2\nevidence:\n  attempt: {_SHORT_HASH_2}\n",
+        body="# B\nFinding B.\n",
+    )
+    group = Group(representative=b, see_also=[a], recency=datetime.now(UTC))
+
+    llm_output = (
+        "TITLE: Combined finding\n"
+        "ATTEMPTS:\n"
+        f"- {_FULL_HASH}: 0.42\n"
+        f"- {_FULL_HASH_2}: 0.55\n"
+        "BODY:\n"
+        "Both notes agree the change improves score.\n"
+    )
+
+    real_replace = os.replace
+
+    def failing_replace(src, dst, *args, **kwargs):
+        # Fail ONLY the final publish rename: src is a mkstemp-named temp
+        # file (".consolidated-<group_id>....md.tmp") and dst is the final
+        # "consolidated-<group_id>.md" name -- both archive moves (member ->
+        # note_archive/) go through for real.
+        if Path(dst).name.startswith("consolidated-") and not Path(dst).name.endswith(".tmp"):
+            raise OSError("simulated failure publishing the consolidated note")
+        return real_replace(src, dst, *args, **kwargs)
+
+    monkeypatch.setattr(os, "replace", failing_replace)
+
+    result = run_consolidation_pass(
+        shared_notes_dir, tmp_path, [group], llm_call=lambda p: llm_output, public_root=public_root
+    )
+
+    assert result is False
+    # Rolled back: both originals restored to shared_notes_dir.
+    assert a.exists()
+    assert b.exists()
+    # No files left archived (the now-empty note_archive/<group_id>/ dir may
+    # still exist -- rollback isn't required to remove it), nothing published.
+    assert [p for p in (public_root / "note_archive").rglob("*") if p.is_file()] == []
+    assert list(shared_notes_dir.glob("consolidated-*.md")) == []
+
+    cache = load_consolidation_cache(public_root)
+    assert len(cache) == 1
+    entry = next(iter(cache.values()))
+    assert entry["status"] == "failed"
+    assert entry["note"] is None
+
+
 def test_orchestrator_unreadable_member_skips_group_silently(tmp_path, monkeypatch):
     public_root, shared_notes_dir = _public_dirs(tmp_path)
     a = _write_note_file(shared_notes_dir / "a.md", "creator: agent-1\n", body="# A\nBody.\n")
