@@ -0,0 +1,601 @@
+"""LLM note consolidation: merge a group of duplicate/overlapping notes into
+one higher-quality note before the publication gate serves them.
+
+Two layers:
+
+  - Primitives (pure, no I/O beyond what's explicitly passed in): prompt
+    construction, output parsing, group-id derivation, and the on-disk cache
+    of past consolidation attempts.
+  - :func:`run_consolidation_pass` — the orchestrator. For every eligible
+    :class:`~coral.hub.publication.Group` it decides whether an LLM call is
+    warranted, calls it (via an injected ``llm_call``, never
+    :func:`default_llm_call` directly — tests must never invoke a real LLM),
+    validates the result against the attempt store, and — only on success —
+    atomically publishes a consolidated note and archives the originals.
+
+Feature flag: this module is only ever driven when ``agents.
+gate_consolidator_model`` is set (see ``coral.config.AgentConfig``); nothing
+here reads that config value itself, matching ``coral.hub.publication``'s
+convention of leaving the "should this run" decision to the caller.
+
+Settle interplay: the on-disk cache (see :func:`load_consolidation_cache`)
+is keyed by :func:`group_id_for`, a hash of the group's member content
+hashes. A cache hit — of *either* status, "consolidated" or "failed" — skips
+the LLM call entirely, so a settled pass never re-spends a call on a group
+it already resolved. Successfully consolidating a group also *archives* its
+member notes out of ``shared_notes_dir`` (see step 7 below), which removes
+the group from existence for the next ``group_notes()`` call — so the
+follow-up publication pass simply finds no such group anymore; the cache
+entry becomes moot rather than needing to be consulted again.
+
+Known v1 edge (accepted): if an agent has an editable *view* copy of a note
+that later gets archived (because its group was successfully consolidated),
+that view copy is orphaned — pruning it from the view is not this module's
+job. If the agent later edits that stale copy, the next harvest pass sees
+new content with no corresponding shared file and treats it as a fresh
+draft, resurrecting the note under its old name. This is accepted: it's the
+same failure mode as any other harvest-vs-external-mutation race elsewhere
+in the publication gate, and correcting it would require the harvest/view
+machinery (out of scope here) to know about archival.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import logging
+import os
+import re
+import subprocess
+import tempfile
+from collections.abc import Callable, Iterable
+from dataclasses import dataclass
+from datetime import UTC, datetime
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+from coral.hub.notes import _parse_frontmatter
+from coral.hub.publication import (
+    _MANIFEST_DIR,
+    Group,
+    _cited_attempt_keys,
+    _resolve_attempt_hash,
+    _sha256_file,
+    _tag_set,
+    _write_if_changed,
+    verify_note,
+)
+from coral.workspace.repo import _clean_env
+
+logger = logging.getLogger(__name__)
+
+# Author identity stamped on every consolidated note. Also what
+# ``verify_note``'s multi-attempt path expects as ``creator`` (that path
+# skips the creator == attempt.agent_id check specifically because a
+# framework-authored aggregate like this one legitimately spans agents).
+CONSOLIDATOR_CREATOR = "coral-consolidator"
+
+# Where the consolidation cache lives, relative to public_root -- the same
+# ``.publication/`` directory publication.py's per-agent manifests use.
+_CACHE_FILENAME = "consolidations.json"
+
+
+# --------------------------------------------------------------------------- #
+# LLM call (never invoked in tests)                                           #
+# --------------------------------------------------------------------------- #
+
+
+def default_llm_call(prompt: str, *, model: str, timeout: int) -> str:
+    """Run one blocking ``claude -p`` call and return its stdout.
+
+    The only I/O primitive in this module that isn't pure. Tests must never
+    call this directly (they inject a fake ``llm_call`` instead) — monkeypatch
+    it to raise if it needs asserting-against.
+
+    Raises ``RuntimeError`` on a non-zero exit or empty stdout. A
+    ``subprocess.TimeoutExpired`` is deliberately not caught here — it
+    propagates to the caller (:func:`run_consolidation_pass` catches it as
+    part of its broad ``except Exception`` around the ``llm_call`` call).
+    """
+    result = subprocess.run(
+        ["claude", "-p", prompt, "--model", model],
+        capture_output=True,
+        text=True,
+        timeout=timeout,
+        env=_clean_env(),
+    )
+    if result.returncode != 0:
+        raise RuntimeError(
+            f"consolidator LLM call exited {result.returncode}: {result.stderr.strip()}"
+        )
+    if not result.stdout.strip():
+        raise RuntimeError("consolidator LLM call returned empty stdout")
+    return result.stdout
+
+
+# --------------------------------------------------------------------------- #
+# Prompt construction                                                         #
+# --------------------------------------------------------------------------- #
+
+
+@dataclass(frozen=True)
+class ConsolidationMember:
+    """One note going into a consolidation prompt.
+
+    ``hashes``/``tags`` are this member's OWN cited-attempt-hashes / tags
+    (not the group's union) -- each member is presented individually so the
+    LLM can see exactly what each source note claims.
+    """
+
+    relpath: str
+    hashes: frozenset[str]
+    tags: frozenset[str]
+    text: str
+
+
+_PROMPT_INSTRUCTIONS = """\
+You are consolidating duplicate research notes from an autonomous coding
+agent team. The notes below all describe overlapping findings and should be
+merged into ONE higher-quality note.
+
+Rules (follow exactly):
+- Merge the notes into a single synthesis. Do not silently drop any finding.
+- Cite EVERY attempt hash listed across ALL notes below -- never omit one,
+  and never invent a hash that isn't listed.
+- Quote each cited attempt's score EXACTLY as given in the notes below --
+  do not round, recompute, average, or otherwise alter it.
+- Respond with EXACTLY this format and nothing else -- no text before it,
+  no text after it, no extra commentary:
+
+TITLE: <one line>
+ATTEMPTS:
+- <hash>: <score>
+BODY:
+<markdown synthesis>
+"""
+
+
+def build_consolidation_prompt(members: list[ConsolidationMember]) -> str:
+    """Build the LLM prompt to merge ``members`` into one note.
+
+    Contains every member's relpath, cited hashes, and tags verbatim (so the
+    LLM has the raw material to satisfy the "cite every hash" / "quote every
+    score exactly" rules), plus the fixed output contract.
+    """
+    parts = [_PROMPT_INSTRUCTIONS, f"\n{len(members)} notes to merge:\n"]
+    for i, member in enumerate(members, start=1):
+        hashes = ", ".join(sorted(member.hashes)) or "(none)"
+        tags = ", ".join(sorted(member.tags)) or "(none)"
+        parts.append(
+            f"\n--- Note {i}: {member.relpath} ---\n"
+            f"Cited attempt hashes: {hashes}\n"
+            f"Tags: {tags}\n"
+            f"Full text:\n{member.text}\n"
+        )
+    return "".join(parts)
+
+
+# --------------------------------------------------------------------------- #
+# Output parsing                                                              #
+# --------------------------------------------------------------------------- #
+
+_FENCE_RE = re.compile(r"^```[A-Za-z0-9_-]*\n(.*)\n```$", re.DOTALL)
+_TITLE_RE = re.compile(r"^TITLE:[ \t]*(.*)$", re.MULTILINE)
+_ATTEMPTS_RE = re.compile(r"^ATTEMPTS:[ \t]*$", re.MULTILINE)
+_BODY_RE = re.compile(r"^BODY:[ \t]*$", re.MULTILINE)
+
+
+def parse_consolidation_output(text: str) -> tuple[str, list[tuple[str, float]], str] | None:
+    """Parse the LLM's response against the ``TITLE:``/``ATTEMPTS:``/``BODY:``
+    contract from :data:`_PROMPT_INSTRUCTIONS`.
+
+    Returns ``(title, [(hash, score), ...], body)`` on success, or ``None`` on
+    ANY structural violation: a missing marker, markers out of order, an
+    empty title, zero parsed attempts, a non-numeric score, or an empty body.
+    Tolerates leading/trailing whitespace and a surrounding markdown code
+    fence around the whole response. Strips a leading ``---`` frontmatter
+    fence from the body if the LLM injected one (it must not — the caller
+    supplies its own frontmatter).
+    """
+    if not text:
+        return None
+    stripped = text.strip()
+    if not stripped:
+        return None
+
+    fence_match = _FENCE_RE.match(stripped)
+    if fence_match:
+        stripped = fence_match.group(1).strip()
+        if not stripped:
+            return None
+
+    title_match = _TITLE_RE.search(stripped)
+    attempts_match = _ATTEMPTS_RE.search(stripped)
+    body_match = _BODY_RE.search(stripped)
+    if not (title_match and attempts_match and body_match):
+        return None
+    if not (title_match.start() < attempts_match.start() < body_match.start()):
+        return None
+
+    title = title_match.group(1).strip()
+    if not title:
+        return None
+
+    attempts_block = stripped[attempts_match.end() : body_match.start()]
+    attempts: list[tuple[str, float]] = []
+    for line in attempts_block.splitlines():
+        line = line.strip()
+        if not line:
+            continue
+        if not line.startswith("-"):
+            continue
+        line = line[1:].strip()
+        if ":" not in line:
+            return None
+        hash_part, _, score_part = line.partition(":")
+        hash_part = hash_part.strip()
+        score_part = score_part.strip()
+        if not hash_part:
+            return None
+        try:
+            score = float(score_part)
+        except ValueError:
+            return None
+        attempts.append((hash_part, score))
+
+    if not attempts:
+        return None
+
+    body = stripped[body_match.end() :].strip("\n")
+    body_lines = body.split("\n")
+    if body_lines and body_lines[0].strip() == "---":
+        for i in range(1, len(body_lines)):
+            if body_lines[i].strip() == "---":
+                body_lines = body_lines[i + 1 :]
+                break
+        body = "\n".join(body_lines)
+    body = body.strip()
+    if not body:
+        return None
+
+    return title, attempts, body
+
+
+# --------------------------------------------------------------------------- #
+# Group id + cache                                                            #
+# --------------------------------------------------------------------------- #
+
+
+def group_id_for(member_content_hashes: Iterable[str]) -> str:
+    """Deterministic, order-independent id for a group of member content hashes."""
+    joined = "\n".join(sorted(member_content_hashes))
+    return hashlib.sha256(joined.encode("utf-8")).hexdigest()[:16]
+
+
+def _cache_path(public_root: str | Path) -> Path:
+    return Path(public_root) / _MANIFEST_DIR / _CACHE_FILENAME
+
+
+def load_consolidation_cache(public_root: str | Path) -> dict[str, dict[str, Any]]:
+    """Load the consolidation cache (``group_id -> record``). Missing/corrupt -> ``{}``."""
+    path = _cache_path(public_root)
+    if not path.exists():
+        return {}
+    try:
+        data = json.loads(path.read_text())
+    except (OSError, json.JSONDecodeError):
+        return {}
+    if not isinstance(data, dict):
+        return {}
+    return data
+
+
+def save_consolidation_cache(public_root: str | Path, cache: dict[str, dict[str, Any]]) -> None:
+    """Save the consolidation cache atomically. No-op if content is unchanged
+    (see ``publication._write_if_changed``)."""
+    path = _cache_path(public_root)
+    payload = json.dumps(cache, indent=2, sort_keys=True) + "\n"
+    _write_if_changed(path, payload.encode("utf-8"))
+
+
+# --------------------------------------------------------------------------- #
+# Orchestrator                                                                #
+# --------------------------------------------------------------------------- #
+
+
+def _resolve_or_raw(coral_dir: str | Path, raw: Any, island_id: str | int | None) -> str | None:
+    """Resolve a cited hash to its full commit hash, else fall back to the raw
+    string -- same resolve-or-raw behavior ``publication._cited_attempt_keys``
+    uses internally, needed here to compare an LLM-parsed hash against the
+    expected set built from that function."""
+    raw = str(raw).strip() if raw else ""
+    if not raw:
+        return None
+    resolved = _resolve_attempt_hash(coral_dir, raw, island_id)
+    return resolved if resolved is not None else raw
+
+
+def _render_frontmatter(
+    *,
+    created_iso: str,
+    tags: list[str],
+    consolidates: list[str],
+    attempts: list[tuple[str, float]],
+) -> str:
+    """Render the candidate note's frontmatter block (without the body)."""
+    payload = {
+        "creator": CONSOLIDATOR_CREATOR,
+        "created": created_iso,
+        "tags": tags,
+        "consolidates": consolidates,
+        "evidence": {"attempts": [{"attempt": h, "score": s} for h, s in attempts]},
+    }
+    dumped = yaml.safe_dump(payload, sort_keys=False, default_flow_style=False).strip("\n")
+    return f"---\n{dumped}\n---\n"
+
+
+def run_consolidation_pass(
+    shared_notes_dir: str | Path,
+    coral_dir: str | Path,
+    groups: list[Group],
+    *,
+    llm_call: Callable[[str], str],
+    public_root: str | Path,
+    island_id: str | int | None = None,
+    now: datetime | None = None,
+) -> bool:
+    """Attempt to consolidate every eligible group of >= 2 notes via one LLM
+    call each. Never raises: every per-group failure -- expected (cache hit,
+    no evidence, malformed LLM output, an archive move that couldn't
+    complete, ...) or unexpected (a bug, a stray exception somewhere in
+    steps 1-7) -- is caught, logged via the module logger, and treated as
+    that group simply failing; the pass always finishes and always persists
+    whatever the cache accumulated, including any earlier group's result.
+
+    Per group:
+
+    1. Compute each member's content sha256 and derive ``group_id`` (see
+       :func:`group_id_for`). A cache hit (any status) skips the group
+       entirely -- no LLM call, nothing recorded.
+    2. Compute the expected attempt-hash set: the union of every member's
+       resolved cited attempts (:func:`publication._cited_attempt_keys` over
+       each member's parsed frontmatter). An empty expected set means no
+       member makes a checkable claim -- the group is skipped with NOTHING
+       recorded (not even a cache entry), so it's reconsidered every pass
+       until it has real evidence to consolidate.
+    3. Build the prompt (:func:`build_consolidation_prompt`) and call
+       ``llm_call(prompt)``. Any exception (including a timeout) is caught
+       and treated as a failure.
+    4. Parse the response (:func:`parse_consolidation_output`); ``None`` is a
+       failure.
+    5. Resolve every parsed hash the same way the expected set was built; the
+       resolved set must equal the expected set exactly, or it's a failure
+       (the LLM cited something it wasn't given, or dropped something it
+       was).
+    6. Render candidate frontmatter + body to a temp file inside
+       ``shared_notes_dir`` and run ``publication.verify_note`` on it. Not
+       verified -> failure: temp file deleted, nothing archived, nothing
+       published.
+    7. Verified -> ARCHIVE FIRST, THEN PUBLISH, so the single atomic
+       ``os.replace`` that makes the consolidated note visible is the LAST
+       thing that can fail, and it's the group's commit point: every
+       original member is atomically moved (``os.replace``, never copied)
+       into ``<public_root>/note_archive/<group_id>/`` first; only once
+       every member has been archived does the temp note become
+       ``consolidated-<group_id>.md`` in ``shared_notes_dir``. If any member
+       fails to archive (vanished mid-pass, cross-device dir, a locked
+       file, ...), archiving stops immediately, everything already archived
+       THIS group is moved back into ``shared_notes_dir`` on a best-effort
+       basis (each move attempted in its own try/except -- a rollback
+       failure is logged, never raised), the temp note is deleted, and the
+       group is recorded as failed. A group therefore never ends up
+       half-archived with its consolidated note already published, and
+       never gets published while a member is still missing.
+    8. Failures record ``status: "failed"`` in the cache (still logged via
+       the module logger) so a broken group isn't retried every pass either
+       -- but member notes and the group itself are left completely
+       untouched, so a human/agent fix to the underlying notes naturally
+       produces a new group_id (different content hash) and gets retried
+       fresh.
+
+    Every group's entire processing (steps 1-7) is wrapped in its own
+    try/except, so one group's unexpected exception is logged and treated
+    as a failed group rather than aborting the loop -- it can never lose an
+    earlier group's already-recorded cache entry.
+
+    The cache is loaded once up front and persisted once after the loop,
+    inside a ``finally`` (see :func:`save_consolidation_cache` -- atomic,
+    and a no-op if content didn't change), so it is saved even if something
+    outside the per-group guard misbehaves. Returns ``True`` iff at least
+    one group was newly consolidated during this call.
+
+    See the module docstring for the settle interplay (why a cache hit plus
+    archival together make repeated passes safe) and the accepted v1 edge
+    around an agent's stale edited view copy of an archived note.
+    """
+    shared_notes_dir = Path(shared_notes_dir)
+    public_root = Path(public_root)
+    now = now or datetime.now(UTC)
+    now_iso = now.isoformat()
+
+    cache = load_consolidation_cache(public_root)
+    any_consolidated = False
+
+    try:
+        for group in groups:
+            try:
+                members_paths = [group.representative, *group.see_also]
+                if len(members_paths) < 2:
+                    continue
+
+                content_hashes: dict[Path, str] = {}
+                readable = True
+                for member_path in members_paths:
+                    digest = _sha256_file(member_path)
+                    if digest is None:
+                        logger.warning(
+                            "consolidation: could not hash %s, skipping group", member_path
+                        )
+                        readable = False
+                        break
+                    content_hashes[member_path] = digest
+                if not readable:
+                    continue
+
+                group_id = group_id_for(content_hashes.values())
+                if group_id in cache:
+                    continue  # cache hit (any status) -- never re-spend an LLM call
+
+                parsed_members: list[ConsolidationMember] = []
+                expected_hashes: set[str] = set()
+                try:
+                    for member_path in members_paths:
+                        text = member_path.read_text()
+                        meta, _ = _parse_frontmatter(text)
+                        member_hashes = _cited_attempt_keys(meta, coral_dir, island_id)
+                        expected_hashes |= set(member_hashes)
+                        parsed_members.append(
+                            ConsolidationMember(
+                                relpath=member_path.relative_to(shared_notes_dir).as_posix(),
+                                hashes=member_hashes,
+                                tags=frozenset(_tag_set(meta)),
+                                text=text,
+                            )
+                        )
+                except OSError as exc:
+                    logger.warning(
+                        "consolidation: could not read members of group %s: %s", group_id, exc
+                    )
+                    continue
+
+                if not expected_hashes:
+                    # No member makes a checkable claim -- nothing to
+                    # consolidate, nothing recorded (reconsidered every
+                    # pass, see docstring).
+                    continue
+
+                member_relpaths = sorted(m.relpath for m in parsed_members)
+
+                def _fail(reason: str) -> None:
+                    logger.warning("consolidation: group %s failed: %s", group_id, reason)
+                    cache[group_id] = {
+                        "status": "failed",
+                        "member_hashes": sorted(content_hashes.values()),
+                        "member_relpaths": member_relpaths,
+                        "note": None,
+                        "at": now_iso,
+                    }
+
+                prompt = build_consolidation_prompt(parsed_members)
+                try:
+                    raw_output = llm_call(prompt)
+                except Exception as exc:  # noqa: BLE001 -- any LLM-call failure is a mundane failure path
+                    _fail(f"llm_call raised {exc!r}")
+                    continue
+
+                parsed = parse_consolidation_output(raw_output)
+                if parsed is None:
+                    _fail("could not parse LLM output")
+                    continue
+                title, parsed_attempts, body = parsed
+
+                resolved = {
+                    resolved_hash
+                    for h, _score in parsed_attempts
+                    if (resolved_hash := _resolve_or_raw(coral_dir, h, island_id)) is not None
+                }
+                if resolved != expected_hashes:
+                    _fail(
+                        f"cited hash set {sorted(resolved)} != expected {sorted(expected_hashes)}"
+                    )
+                    continue
+
+                tags = sorted({t for m in parsed_members for t in m.tags})
+                frontmatter = _render_frontmatter(
+                    created_iso=now_iso,
+                    tags=tags,
+                    consolidates=member_relpaths,
+                    attempts=parsed_attempts,
+                )
+                content = f"{frontmatter}\n# {title}\n\n{body}\n"
+
+                fd, tmp_path_str = tempfile.mkstemp(
+                    prefix=f".consolidated-{group_id}.", suffix=".md.tmp", dir=shared_notes_dir
+                )
+                tmp_path = Path(tmp_path_str)
+                try:
+                    with os.fdopen(fd, "w") as f:
+                        f.write(content)
+                        f.flush()
+                        os.fsync(f.fileno())
+
+                    verdict = verify_note(tmp_path, coral_dir, island_id)
+                except Exception as exc:  # noqa: BLE001 -- never let a group failure propagate
+                    _fail(f"unexpected error authoring candidate note: {exc!r}")
+                    tmp_path.unlink(missing_ok=True)
+                    continue
+
+                if verdict.verified is not True:
+                    _fail(f"candidate note did not verify: {verdict.reason}")
+                    tmp_path.unlink(missing_ok=True)
+                    continue
+
+                # Archive-first-then-publish (see docstring step 7): move
+                # every member into note_archive/<group_id>/ BEFORE
+                # publishing the consolidated note. A failure partway
+                # through is rolled back on a best-effort basis and never
+                # propagates.
+                archive_dir = public_root / "note_archive" / group_id
+                archived: list[Path] = []
+                archive_error: OSError | None = None
+                try:
+                    archive_dir.mkdir(parents=True, exist_ok=True)
+                    for member_path in members_paths:
+                        os.replace(member_path, archive_dir / member_path.name)
+                        archived.append(member_path)
+                except OSError as exc:
+                    archive_error = exc
+
+                if archive_error is not None:
+                    logger.warning(
+                        "consolidation: group %s failed to archive a member: %r",
+                        group_id,
+                        archive_error,
+                    )
+                    for original_path in archived:
+                        try:
+                            os.replace(archive_dir / original_path.name, original_path)
+                        except OSError as rollback_exc:
+                            logger.warning(
+                                "consolidation: group %s rollback failed for %s: %r",
+                                group_id,
+                                original_path,
+                                rollback_exc,
+                            )
+                    tmp_path.unlink(missing_ok=True)
+                    _fail(f"archiving members failed: {archive_error!r}")
+                    continue
+
+                final_path = shared_notes_dir / f"consolidated-{group_id}.md"
+                os.replace(tmp_path, final_path)
+
+                cache[group_id] = {
+                    "status": "consolidated",
+                    "member_hashes": sorted(content_hashes.values()),
+                    "member_relpaths": member_relpaths,
+                    "note": final_path.relative_to(shared_notes_dir).as_posix(),
+                    "at": now_iso,
+                }
+                any_consolidated = True
+            except Exception as exc:  # noqa: BLE001 -- one group's bug must never abort the pass
+                logger.warning(
+                    "consolidation: group (representative=%s) raised unexpectedly: %r",
+                    group.representative,
+                    exc,
+                )
+    finally:
+        save_consolidation_cache(public_root, cache)
+
+    return any_consolidated
