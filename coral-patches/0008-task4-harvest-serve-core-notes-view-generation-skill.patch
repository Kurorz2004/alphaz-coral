+    # Re-stamp: this pass the citation no longer resolves (e.g. the attempt
+    # it cited disappeared). The stale coral_verified: true must not keep
+    # rendering the note as verified.
+    stamp_verdicts(
+        shared_notes_dir,
+        {note: Verdict(verified="unverifiable", confidence="medium", reason="cited attempt not found")},
+    )
+    formatted2 = format_notes_list(list_notes(tmp_path))
+
+    assert formatted2.endswith("[unverified]")
+    assert "[verified" not in formatted2
