+    first_consolidated = list(shared_notes_dir.glob("consolidated-*.md"))
+    assert len(first_consolidated) == 1
+    first_name = first_consolidated[0].name
+
+    # A third note (by agent2) citing one of the same attempts -- Rule 1
+    # set-intersection groups it with the existing consolidated note.
+    _write_note_file(
