+def _dir_mtime_signature(directory: Path) -> tuple[float, int]:
+    """(max mtime, file count) for every file under ``directory``, recursively.
+
+    Cheap, order-independent proxy for "did anything change" — used by
+    :meth:`AgentManager._publication_pass_signature`. A missing directory
+    signs as ``(0.0, 0)``, distinct from any populated directory's
+    signature (file count >= 1 once anything exists).
+    """
+    if not directory.is_dir():
+        return (0.0, 0)
+    max_mtime = 0.0
+    count = 0
+    for path in directory.rglob("*"):
+        if not path.is_file():
+            continue
+        count += 1
+        try:
+            max_mtime = max(max_mtime, path.stat().st_mtime)
+        except OSError:
+            continue
+    return (max_mtime, count)
+
