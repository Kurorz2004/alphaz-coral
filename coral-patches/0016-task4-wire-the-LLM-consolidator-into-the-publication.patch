@@ -0,0 +1,479 @@
+"""Integration tests for the LLM note consolidator wired into
+``AgentManager._do_publication_pass`` (``coral/agent/manager.py``).
+
+Unlike ``tests/test_gate_consolidation_core.py`` (which drives
+``coral.hub.consolidation.run_consolidation_pass`` directly), these tests
+exercise the real manager entrypoint (``_run_publication_pass``) end to end:
+agent-authored note drafts sitting in a served view get harvested, verified/
+stamped, grouped, optionally consolidated, and mirrored back out to every
+live agent's view + index.
+
+A real LLM is never invoked here -- every test injects a fake callable via
+``mgr._gate_llm_call`` (see that attribute's docstring in
+``AgentManager.__init__``), and the autouse ``_forbid_real_llm_call``
+fixture monkeypatches :func:`coral.hub.consolidation.default_llm_call` to
+raise, so any accidental code path reaching for the real thing fails loudly.
+
+Fixture helpers (``_make_manager`` / ``_make_handle`` / ``_make_attempt`` /
+``_write_note_file``) mirror ``tests/test_publication_gate.py``'s Task 9
+harness so the suites read the same way; kept local (not imported) since
+this file must not depend on that one's internals shifting -- same
+convention as ``tests/test_gate_consolidation.py`` / ``test_gate_consolidation_core.py``.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from coral.config import CoralConfig
+from coral.hub.attempts import write_attempt
+from coral.hub.consolidation import load_consolidation_cache
+from coral.hub.notes import _parse_frontmatter
+from coral.types import Attempt
+
+# --------------------------------------------------------------------------- #
+# Fixture helpers                                                             #
+# --------------------------------------------------------------------------- #
+
+_FULL_HASH = "7b1e4d001122334455667788990011223344aabb"
+_SHORT_HASH = _FULL_HASH[:12]
+_FULL_HASH_2 = "9c2f5e112233445566778899001122334455bbcc"
+_SHORT_HASH_2 = _FULL_HASH_2[:12]
+_FULL_HASH_3 = "aa11bb22cc33dd44ee55ff66001122334455aabb"
+_SHORT_HASH_3 = _FULL_HASH_3[:12]
+
+# Near-identical tag sets: intersection 3 / union 5 = 0.6 >= 0.5 -> Rule 2 groups.
+_TAGS_A = "tiling, matmul, cache, perf"
+_TAGS_B = "tiling, matmul, cache, alignment"
+
+
+@pytest.fixture(autouse=True)
+def _forbid_real_llm_call(monkeypatch):
+    """Safety net: nothing in this suite may ever reach the real LLM call."""
+
+    def _boom(*args, **kwargs):
+        raise AssertionError("default_llm_call must never be invoked by tests")
+
+    monkeypatch.setattr("coral.hub.consolidation.default_llm_call", _boom)
+
+
+def _make_attempt(
+    commit: str,
+    agent: str = "island-0-agent-2",
+    score: float | None = 0.42,
+    metadata: dict | None = None,
+) -> Attempt:
+    return Attempt(
+        commit_hash=commit,
+        agent_id=agent,
+        title="a change",
+        score=score,
+        status="improved" if score is not None else "pending",
+        parent_hash=None,
+        timestamp="2026-03-14T17:00:00-00:00",
+        metadata=metadata or {},
+    )
+
+
+def _write_note(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(text)
+
+
+def _write_note_file(path: Path, frontmatter: str, body: str = "# Title\nBody text.\n") -> Path:
+    _write_note(path, f"---\n{frontmatter}\n---\n\n{body}")
+    return path
+
+
+def _make_manager(
+    tmp_path: Path,
+    *,
+    publication_gate: bool,
+    knowledge: bool = True,
+    islands_count: int = 1,
+):
+    """A real ``AgentManager`` (mirrors test_publication_gate.py's Task 9
+    ``_make_manager``) with 2 agents, but no live subprocess --
+    ``paths``/``handles`` are set directly rather than going through
+    ``start_all()``."""
+    from coral.agent.manager import AgentManager
+    from coral.workspace.project import ProjectPaths
+
+    cfg = CoralConfig.from_dict(
+        {
+            "task": {"name": "t", "description": "d"},
+            "agents": {
+                "count": 2,
+                "timeout": 1,
+                "publication_gate": publication_gate,
+                "knowledge": knowledge,
+            },
+            "islands": {"count": islands_count},
+        }
+    )
+    mgr = AgentManager(cfg)
+    coral_dir = tmp_path / ".coral"
+    mgr.paths = ProjectPaths(
+        results_dir=tmp_path,
+        task_dir=tmp_path,
+        run_dir=tmp_path,
+        coral_dir=coral_dir,
+        agents_dir=tmp_path / "agents",
+        repo_dir=tmp_path / "repo",
+    )
+    return mgr, coral_dir
+
+
+def _make_handle(agent_id: str, worktree_path: Path, log_path: Path):
+    from coral.agent.runtime import AgentHandle
+
+    worktree_path.mkdir(parents=True, exist_ok=True)
+    return AgentHandle(agent_id=agent_id, process=None, worktree_path=worktree_path, log_path=log_path)
+
+
+def _consolidation_response(
+    pairs: list[tuple[str, float]], *, title: str = "Combined finding", body: str = "Combined synthesis.\n"
+) -> str:
+    lines = [f"TITLE: {title}", "ATTEMPTS:"]
+    lines += [f"- {h}: {s}" for h, s in pairs]
+    lines += ["BODY:", body]
+    return "\n".join(lines) + "\n"
+
+
+def _setup_two_agent_group(mgr, coral_dir: Path) -> tuple[str, str, Path, Path]:
+    """Two live agents, two real scored attempts, two agent-authored draft
+    notes (near-identical tags -> group via Rule 2) sitting in each agent's
+    served view, ready to be harvested. Returns
+    ``(agent1_id, agent2_id, agent1_worktree, agent2_worktree)``.
+    """
+    agent1_id, agent2_id = (s.agent_id for s in mgr.specs)
+    (coral_dir / "public" / "notes").mkdir(parents=True)
+    (coral_dir / "public" / "attempts").mkdir(parents=True)
+
+    write_attempt(coral_dir, _make_attempt(_FULL_HASH, agent=agent1_id, score=0.42))
+    write_attempt(coral_dir, _make_attempt(_FULL_HASH_2, agent=agent2_id, score=0.55))
+
+    agent1_worktree = mgr.paths.agents_dir / agent1_id
+    agent2_worktree = mgr.paths.agents_dir / agent2_id
+    mgr.handles = [
+        _make_handle(agent1_id, agent1_worktree, agent1_worktree.parent / "a1.log"),
+        _make_handle(agent2_id, agent2_worktree, agent2_worktree.parent / "a2.log"),
+    ]
+    for wt in (agent1_worktree, agent2_worktree):
+        (wt / ".claude" / "notes").mkdir(parents=True)
+        (wt / ".claude" / "skills").mkdir(parents=True)
+
+    _write_note_file(
+        agent1_worktree / ".claude" / "notes" / "a.md",
+        f"creator: {agent1_id}\n"
+        "created: 2026-03-10T00:00:00-00:00\n"
+        f"tags: [{_TAGS_A}]\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH}\n"
+        '  score: "0.4200"\n',
+        body="# A\nFinding A.\n",
+    )
+    _write_note_file(
+        agent2_worktree / ".claude" / "notes" / "b.md",
+        f"creator: {agent2_id}\n"
+        "created: 2026-03-11T00:00:00-00:00\n"
+        f"tags: [{_TAGS_B}]\n"
+        "evidence:\n"
+        f"  attempt: {_SHORT_HASH_2}\n"
+        '  score: "0.5500"\n',
+        body="# B\nFinding B.\n",
+    )
+    return agent1_id, agent2_id, agent1_worktree, agent2_worktree
+
+
+# --------------------------------------------------------------------------- #
+# (a) happy path                                                              #
+# --------------------------------------------------------------------------- #
+
+
+def test_consolidation_happy_path_archives_originals_and_serves_only_consolidated(tmp_path):
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    _agent1_id, _agent2_id, agent1_worktree, agent2_worktree = _setup_two_agent_group(mgr, coral_dir)
+
+    calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        calls.append(prompt)
+        return _consolidation_response([(_FULL_HASH, 0.42), (_FULL_HASH_2, 0.55)])
+
+    mgr._gate_llm_call = fake_llm
+
+    for _ in range(3):  # settle: active pass + cheap follow-up(s)
+        mgr._run_publication_pass()
+
+    assert len(calls) == 1
+
+    public_root = coral_dir / "public"
+    shared_notes_dir = public_root / "notes"
+
+    consolidated_files = list(shared_notes_dir.glob("consolidated-*.md"))
+    assert len(consolidated_files) == 1
+    consolidated_name = consolidated_files[0].name
+    consolidated_text = consolidated_files[0].read_text()
+    assert "coral_verified: true" in consolidated_text
+
+    # Originals gone from shared notes.
+    assert not (shared_notes_dir / "a.md").exists()
+    assert not (shared_notes_dir / "b.md").exists()
+
+    # Both originals archived together under one note_archive/<group_id>/ dir.
+    archive_dirs = list((public_root / "note_archive").iterdir())
+    assert len(archive_dirs) == 1
+    assert sorted(p.name for p in archive_dirs[0].iterdir()) == ["a.md", "b.md"]
+
+    # Both agents' views + index contain ONLY the consolidated note -- no
+    # see-also, originals absent from view dirs entirely.
+    for wt in (agent1_worktree, agent2_worktree):
+        view_notes_dir = wt / ".claude" / "notes"
+        assert not (view_notes_dir / "a.md").exists()
+        assert not (view_notes_dir / "b.md").exists()
+        assert (view_notes_dir / consolidated_name).exists()
+
+        md_files = {p.name for p in view_notes_dir.glob("*.md") if p.name != "index.md"}
+        assert md_files == {consolidated_name}
+
+        index_text = (view_notes_dir / "index.md").read_text()
+        assert "Combined finding" in index_text
+        assert "see also" not in index_text
+
+
+# --------------------------------------------------------------------------- #
+# (b) hallucinated score                                                      #
+# --------------------------------------------------------------------------- #
+
+
+def test_consolidation_hallucinated_score_leaves_originals_and_records_failure(tmp_path):
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    _agent1_id, _agent2_id, agent1_worktree, agent2_worktree = _setup_two_agent_group(mgr, coral_dir)
+
+    calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        calls.append(prompt)
+        # Wrong score for the second hash -- real score is 0.55.
+        return _consolidation_response([(_FULL_HASH, 0.42), (_FULL_HASH_2, 0.99)])
+
+    mgr._gate_llm_call = fake_llm
+
+    for _ in range(3):
+        mgr._run_publication_pass()
+
+    assert len(calls) == 1  # cache records the failure -> not retried on follow-up
+
+    public_root = coral_dir / "public"
+    shared_notes_dir = public_root / "notes"
+
+    assert list(shared_notes_dir.glob("consolidated-*.md")) == []
+    assert not (public_root / "note_archive").exists()
+
+    # Originals intact in shared state and in both agents' views.
+    assert (shared_notes_dir / "a.md").exists()
+    assert (shared_notes_dir / "b.md").exists()
+    assert (agent1_worktree / ".claude" / "notes" / "a.md").exists()
+    assert (agent2_worktree / ".claude" / "notes" / "b.md").exists()
+
+    # See-also representation still present in the index.
+    index_text = (agent1_worktree / ".claude" / "notes" / "index.md").read_text()
+    assert "see also" in index_text
+
+    cache = load_consolidation_cache(public_root)
+    assert len(cache) == 1
+    assert next(iter(cache.values()))["status"] == "failed"
+
+
+# --------------------------------------------------------------------------- #
+# (c) LLM raises                                                              #
+# --------------------------------------------------------------------------- #
+
+
+def test_consolidation_llm_exception_leaves_originals_and_records_failure(tmp_path):
+    mgr, coral_dir = _make_manager(tmp_path, publication_gate=True)
+    _agent1_id, _agent2_id, agent1_worktree, agent2_worktree = _setup_two_agent_group(mgr, coral_dir)
+
+    calls: list[str] = []
+
+    def fake_llm(prompt: str) -> str:
+        calls.append(prompt)
